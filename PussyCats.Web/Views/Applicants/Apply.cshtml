@using PussyCats.Web.Dtos
@{
    ViewData["Title"] = "Apply for Job";
    var job = ViewBag.Job as JobPostingDto;
    bool alreadyApplied = (bool?)(ViewBag.AlreadyApplied) ?? false;
}

<div class="mb-3">
    <a asp-action="Details" asp-controller="Jobs" asp-route-id="@job?.JobId" class="btn btn-outline-secondary btn-sm">&larr; Back to Job</a>
</div>

<div class="card shadow-sm">
    <div class="card-header">
        <h2 class="mb-0">Apply for: @job?.JobTitle</h2>
    </div>
    <div class="card-body">
        @if (alreadyApplied)
        {
            <div class="alert alert-warning">
                <strong>Already Applied</strong>
                <p class="mb-2">You have already submitted an application for this job. You cannot apply twice.</p>
            </div>

            <a asp-action="Details" asp-controller="Jobs" asp-route-id="@job?.JobId" class="btn btn-primary mt-3">Back to Job Details</a>
            <a asp-action="Index" asp-controller="Jobs" class="btn btn-outline-secondary mt-3">View All Jobs</a>
        }
        else
        {
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="alert alert-info mb-4">
                <h5>Job Details</h5>
                <p class="mb-0">
                    <strong>Position:</strong> @job?.JobTitle<br />
                    <strong>Location:</strong> @(job?.JobLocation ?? "â€”")<br />
                    <strong>Type:</strong> @(job?.JobType ?? "â€”")<br />
                    @if (job?.Salary.HasValue == true)
                    {
                        <span><strong>Salary:</strong> @job.Salary.Value.ToString("N0") RON<br /></span>
                    }
                    <strong>Deadline:</strong> @(job?.Deadline?.ToString("dd MMM yyyy") ?? "â€”")
                </p>
            </div>

            <form asp-action="SubmitApplication" asp-route-jobId="@job?.JobId" method="post">
                @Html.AntiForgeryToken()

                <div class="alert alert-info">
                    <p class="mb-0">By submitting this application, you confirm that the information you provide is accurate and complete.</p>
                </div>

                <div class="mb-3">
                    <button type="submit" class="btn btn-success btn-lg">Submit Application</button>
                    <a asp-action="Details" asp-controller="Jobs" asp-route-id="@job?.JobId" class="btn btn-outline-secondary btn-lg">Cancel</a>
                </div>
            </form>
        }
    </div>
</div>

