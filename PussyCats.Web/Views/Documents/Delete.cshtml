@model PussyCats.Library.Domain.Document
@{
	ViewData["Title"] = "Delete Document";
}

<h1>Delete Document</h1>

<h3>Are you sure you want to delete this?</h3>

<div>
	<dl class="row">
		<dt class="col-sm-2">
			<label asp-for="DocumentName"></label>
		</dt>
		<dd class="col-sm-10">@Model.DocumentName</dd>

		<dt class="col-sm-2">
			<label asp-for="FilePath"></label>
		</dt>
		<dd class="col-sm-10">@Model.FilePath</dd>

		<dt class="col-sm-2">
			<label asp-for="UploadDate"></label>
		</dt>
		<dd class="col-sm-10">@Model.UploadDate.ToString("g")</dd>

		<dt class="col-sm-2">
			<label>User</label>
		</dt>
		<dd class="col-sm-10">@Model.User?.Name</dd>
	</dl>
</div>

<form asp-action="Delete" method="post">
	@Html.AntiForgeryToken()
	<input type="hidden" asp-for="DocumentId" />
	<input type="hidden" name="userId" value="@Model.User?.UserId" />
	<button type="submit" class="btn btn-danger">Delete</button>
	<a class="btn btn-secondary" asp-action="Index" asp-route-userId="@Model.User?.UserId">Cancel</a>
</form>
