@model PussyCats.Web.Models.DocumentFormModel
@{
	ViewData["Title"] = "Edit Document";
	var userOptions = ViewBag.Users as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? new();
}

<h1>Edit Document</h1>

<form asp-action="Edit" asp-route-id="@Model.DocumentId" method="post">
	@Html.AntiForgeryToken()
	<input type="hidden" asp-for="DocumentId" />
	<input type="hidden" asp-for="UserId" />
	<div asp-validation-summary="ModelOnly" class="text-danger"></div>

	<div class="mb-3">
		<label asp-for="UserId" class="form-label">User</label>
		<select asp-for="UserId" asp-items="userOptions" class="form-select" disabled>
		</select>
		<small class="form-text text-muted">User cannot be changed on an existing document.</small>
	</div>

	<div class="mb-3">
		<label asp-for="DocumentName" class="form-label">Document Name</label>
		<input asp-for="DocumentName" class="form-control" />
		<span asp-validation-for="DocumentName" class="text-danger"></span>
	</div>

	<button type="submit" class="btn btn-primary">Save</button>
	<a class="btn btn-secondary" asp-action="Index" asp-route-userId="@Model.UserId">Cancel</a>
</form>

@section Scripts {
	<partial name="_ValidationScriptsPartial" />
}
