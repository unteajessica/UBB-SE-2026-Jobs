@model PussyCats.Library.Domain.Document
@{
	ViewData["Title"] = "Document Details";
}

<h1>@Model.DocumentName</h1>

<div>
	<dl class="row">
		<dt class="col-sm-2">
			<label asp-for="DocumentId"></label>
		</dt>
		<dd class="col-sm-10">@Model.DocumentId</dd>

		<dt class="col-sm-2">
			<label asp-for="DocumentName"></label>
		</dt>
		<dd class="col-sm-10">@Model.DocumentName</dd>

		<dt class="col-sm-2">
			<label asp-for="FilePath"></label>
		</dt>
		<dd class="col-sm-10">@Model.FilePath</dd>

		<dt class="col-sm-2">
			<label asp-for="UploadDate"></label>
		</dt>
		<dd class="col-sm-10">@Model.UploadDate.ToString("g")</dd>

		<dt class="col-sm-2">
			<label>User</label>
		</dt>
		<dd class="col-sm-10">@Model.User?.Name</dd>
	</dl>
</div>

<div>
	<a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.DocumentId">Edit</a>
	<a class="btn btn-secondary" asp-action="Index">Back to List</a>
</div>
