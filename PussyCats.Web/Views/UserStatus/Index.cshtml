@model IReadOnlyList<PussyCats.Library.DTOs.ApplicationCardModel>
@{
    ViewData["Title"] = "My Applications";
    var currentFilter = ViewBag.CurrentFilter as string ?? "All";
    var totalCount = (int)(ViewBag.TotalCount ?? 0);
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>My Applications <span class="badge bg-secondary">@totalCount total</span></h2>
    </div>

    <div class="btn-group mb-4" role="group">
        @foreach (var filter in new[] { "All", "Applied", "Accepted", "Rejected" })
        {
            <a asp-controller="UserStatus" asp-action="Index" asp-route-filter="@(filter == "All" ? null : filter)"
               class="btn @(currentFilter == filter ? "btn-primary" : "btn-outline-primary")">
                @filter
            </a>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">No applications found for this filter.</div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var app in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title mb-0">@app.CompanyName</h5>
                                @{
                                    var badgeClass = app.Status switch
                                    {
                                        PussyCats.Library.Domain.Enums.MatchStatus.Applied  => "bg-warning text-dark",
                                        PussyCats.Library.Domain.Enums.MatchStatus.Accepted => "bg-success",
                                        PussyCats.Library.Domain.Enums.MatchStatus.Rejected => "bg-danger",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @badgeClass">@app.Status</span>
                            </div>
                            <p class="card-text text-muted small">@app.TruncatedDescription</p>
                            <div class="mb-2">
                                <small class="text-muted">Compatibility</small>
                                <div class="progress" style="height: 8px;">
                                    @{
                                        var progressClass = app.CompatibilityScore >= 70 ? "bg-success"
                                            : app.CompatibilityScore >= 40 ? "bg-warning"
                                            : "bg-danger";
                                    }
                                    <div class="progress-bar @progressClass" role="progressbar"
                                         style="width: @app.CompatibilityScore%"
                                         aria-valuenow="@app.CompatibilityScore" aria-valuemin="0" aria-valuemax="100">
                                    </div>
                                </div>
                                <small class="text-muted">@app.FormattedScore</small>
                            </div>
                            @if (app.HasFeedback)
                            {
                                <div class="alert alert-light py-1 px-2 mb-0 mt-2 small">
                                    <strong>Feedback:</strong> @app.FeedbackMessage
                                </div>
                            }
                        </div>
                        <div class="card-footer text-muted small">
                            @app.FormattedDate
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
