@model List<PussyCats.Web.Dtos.QuestionDto>

@{
    ViewData["Title"] = "Questions";
    var testId = ViewBag.TestId as int?;
    var count = ViewBag.QuestionCount as int? ?? Model.Count;
    var remaining = ViewBag.RemainingToTarget as int? ?? Math.Max(0, 25 - count);
}

<div class="container mt-4">
    <h2 class="fw-bold mb-3">Questions @if(testId != null){<span class="text-muted">for Test #@testId</span>} @if(ViewBag.TestTitle != null){<span class="text-muted">(@ViewBag.TestTitle)</span>}</h2>

    <div class="mb-3">
        <span class="badge bg-light text-dark">Total questions: @count</span>
        <span class="badge bg-secondary ms-2">Remaining to 25: @remaining</span>
    </div>

    @if (User.IsInRole("Recruiter") || User.IsInRole("Admin")) {
        <div class="mb-3">
            <a asp-action="Create" asp-route-testId="@testId" class="btn btn-success">+ Add Question</a>
            <a asp-controller="Tests" asp-action="Index" class="btn btn-secondary ms-2">Back to Tests</a>
        </div>
    }

    <div class="list-group">
        @foreach(var q in Model)
        {
            <div class="list-group-item">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h5 class="mb-1">@q.QuestionText</h5>
                        <small class="text-muted">Type: @q.QuestionType — Score: @q.QuestionScore</small>
                    </div>
                    <div class="btn-group">
                        <a asp-action="Details" asp-route-id="@q.Id" class="btn btn-outline-secondary btn-sm">Details</a>
                        @if (User.IsInRole("Recruiter") || User.IsInRole("Admin")) {
                            <a asp-action="Edit" asp-route-id="@q.Id" class="btn btn-warning btn-sm">Edit</a>
                            <a asp-action="Delete" asp-route-id="@q.Id" class="btn btn-danger btn-sm">Delete</a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

</div>

