@model List<PussyCats.Web.Dtos.InterviewSessionDto>

@{
    ViewData["Title"] = "Booked Interviews";
}

<div class="container py-4">

    <div class="mb-4 pb-3 border-bottom d-flex align-items-center justify-content-between">
        <div>
            <h2 class="fw-bold text-dark">Booked Interviews</h2>
            <div class="text-muted small">All scheduled interview sessions assigned to you.</div>
        </div>
        <a asp-action="ManageSlots" class="btn btn-sm" style="background:#F0EEFF;color:#5038C8;">
            Manage Slots
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="p-4 rounded text-center" style="background:#F0EEFF;">
            <p class="text-muted mb-0">No interviews have been booked yet.</p>
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead style="background:#F0EEFF;">
                        <tr>
                            <th class="px-4 py-3">#</th>
                            <th class="py-3">Candidate</th>
                            <th class="py-3">Position</th>
                            <th class="py-3">Date &amp; Time</th>
                            <th class="py-3">Status</th>
                            <th class="py-3">Score</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var session in Model)
                        {
                            <tr>
                                <td class="px-4">@session.Id</td>
                                <td>
                                    @if (session.ExternalUserId.HasValue)
                                    {
                                        <span>Candidate #@session.ExternalUserId</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>Position #@session.PositionId</td>
                                <td>@session.DateStart.ToString("dd MMM yyyy, HH:mm")</td>
                                <td>
                                    @{
                                        string badgeClass = session.Status switch
                                        {
                                            "Scheduled" => "bg-primary",
                                            "Completed" => "bg-success",
                                            "Cancelled" => "bg-danger",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @badgeClass">
                                        @(session.Status ?? "Unknown")
                                    </span>
                                </td>
                                <td>
                                    @if (session.Score.HasValue)
                                    {
                                        <span class="fw-semibold">@session.Score.Value.ToString("0.##")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

</div>
