@model ProfileViewModel

@{
    ViewData["Title"] = "My Profile";
}

<div class="container py-4">
    <div class="card shadow-sm">
        <div class="card-body p-4">
            <h2 class="mb-4">My Profile</h2>

            <div class="row mb-3">
                <div class="col-sm-3 fw-bold">Id</div>
                <div class="col-sm-9">@Model.Id</div>
            </div>

            <div class="row mb-3">
                <div class="col-sm-3 fw-bold">Name</div>
                <div class="col-sm-9">@Model.Name</div>
            </div>

            <div class="row mb-3">
                <div class="col-sm-3 fw-bold">Email</div>
                <div class="col-sm-9">@Model.Email</div>
            </div>

            <div class="row mb-4">
                <div class="col-sm-3 fw-bold">Role</div>
                <div class="col-sm-9">@Model.Role</div>
            </div>

            <h4>CV XML</h4>

            @if (Model.HasCv)
            {
                <pre class="bg-light border rounded p-3">@Model.CvXml</pre>
            }
            else
            {
                <div class="alert alert-secondary mb-0">
                    No CV uploaded yet.
                </div>
            }
        </div>
    </div>
</div>