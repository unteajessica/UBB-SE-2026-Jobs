@inject PussyCats.Web.Configuration.ApiConfiguration ApiConfiguration
@using PussyCats.Web.Infrastructure
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PussyCats.Web</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PussyCats.Web.styles.css" asp-append-version="true" />
</head>
<body class="pc-body">
    @{
        var selectedMode = Context.Session.GetString(SessionKeys.Mode);
        var isUserMode = string.Equals(selectedMode, AppModes.User, StringComparison.OrdinalIgnoreCase);
        var isCompanyMode = string.Equals(selectedMode, AppModes.Company, StringComparison.OrdinalIgnoreCase);
        var isDeveloperMode = string.Equals(selectedMode, AppModes.Developer, StringComparison.OrdinalIgnoreCase);
    }
    <div class="d-flex">
	    <div id="sidebar" class="pc-sidebar d-flex flex-column flex-shrink-0 p-3" style="width: 250px; min-height: 100vh; transition: width 0.2s ease; overflow: hidden;">
		    <ul class="nav nav-pills flex-column gap-1">
			    @if (User.Identity?.IsAuthenticated == true)
			    {
				    <li class="nav-item">
					    <span class="nav-link text-dark fw-semibold">
						    <i class="bi bi-person-circle me-2"></i><span class="sidebar-label">@User.Identity.Name</span>
					    </span>
				    </li>
				    <li class="nav-item">
					    <form asp-controller="Account" asp-action="Logout" method="post">
						    <button type="submit" class="nav-link text-dark btn btn-link w-100 text-start">
							    <i class="bi bi-box-arrow-right me-2"></i><span class="sidebar-label">Logout</span>
						    </button>
					    </form>
				    </li>
			    }
			    else
			    {
				    @if (isUserMode)
				    {
					    <li class="nav-item">
						    <a class="nav-link text-dark" asp-controller="Account" asp-action="Login">
							    <i class="bi bi-box-arrow-in-right me-2"></i><span class="sidebar-label">Login</span>
						    </a>
					    </li>
				    }
			    }
			    <li class="nav-item">
				    <a class="nav-link text-dark" asp-controller="Home" asp-action="SwitchMode">
					    <i class="bi bi-arrow-left-right me-2"></i><span class="sidebar-label">Switch Mode</span>
				    </a>
			    </li>
		    </ul>
		    <div class="d-flex align-items-center justify-content-between mb-3">
			    <span id="sidebar-brand" class="fw-semibold text-dark">Menu</span>
			    <button id="sidebar-toggle" class="btn btn-sm btn-outline-secondary border-0" title="Collapse sidebar">
				    <span class="navbar-toggler-icon" style="width: 1.2em; height: 1.2em;"></span>
			    </button>
		    </div>

		    <ul class="nav nav-pills flex-column mb-auto gap-1">
			    <li class="nav-item">
				    <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">
					    <i class="bi bi-house me-2"></i><span class="sidebar-label">Home</span>
				    </a>
			    </li>
			    @if (isUserMode)
			    {
				    <li class="nav-item">
					    <a class="nav-link text-dark" asp-controller="JobBrowser" asp-action="Index">
						    <i class="bi bi-briefcase me-2"></i><span class="sidebar-label">Browse Jobs</span>
					    </a>
				    </li>
				    <li class="nav-item">
					    <a class="nav-link text-dark" asp-controller="UserStatus" asp-action="Index">
						    <i class="bi bi-send me-2"></i><span class="sidebar-label">My Applications</span>
					    </a>
				    </li>
				    <li class="nav-item">
					    <a class="nav-link text-dark" asp-controller="UserProfile" asp-action="Index">
						    <i class="bi bi-person me-2"></i><span class="sidebar-label">My Profile</span>
					    </a>
				    </li>
				    <li class="nav-item">
					    <a class="nav-link text-dark" asp-controller="UserProfile" asp-action="Edit">
						    <i class="bi bi-person me-2"></i><span class="sidebar-label">Edit Profile</span>
					    </a>
				    </li>

				    <li class="nav-item">
					    <a class="nav-link text-dark" asp-controller="SkillTests" asp-action="Index">
						    <i class="bi bi-clipboard-check me-2"></i><span class="sidebar-label">Skill Tests</span>
					    </a>
				    </li>
				    <li class="nav-item">
					    <a class="nav-link text-dark" asp-controller="PersonalityTest" asp-action="Index">
						    <i class="bi bi-stars me-2"></i><span class="sidebar-label">Personality Test</span>
					    </a>
				    </li>
				    <li class="nav-item">
					    <a class="nav-link text-dark" asp-controller="Compatibility" asp-action="Index">
						    <i class="bi bi-puzzle me-2"></i><span class="sidebar-label">Compatibility</span>
					    </a>
				    </li>
				    <li class="nav-item">
					    <a class="nav-link text-dark" asp-controller="Documents" asp-action="Index">
						    <i class="bi bi-file-earmark me-2"></i><span class="sidebar-label">Documents</span>
					    </a>
				    </li>
				    <li class="nav-item">
					    <a class="nav-link text-dark" asp-controller="Chat" asp-action="Index">
						    <i class="bi bi-chat me-2"></i><span class="sidebar-label">Chat</span>
					    </a>
				    </li>
				    <li class="nav-item">
					    <a class="nav-link text-dark" asp-controller="Preferences" asp-action="Index">
						    <i class="bi bi-sliders me-2"></i><span class="sidebar-label">Preferences</span>
					    </a>
				    </li>
				    
			    }
			    @if (isCompanyMode)
			    {
				    <li class="nav-item">
					    <a class="nav-link text-dark" asp-controller="Company" asp-action="Profile" asp-route-id="@ApiConfiguration.TemporaryCompanyId">
						    <i class="bi bi-building me-2"></i><span class="sidebar-label">Company</span>
					    </a>
				    </li>
				    <li class="nav-item">
					    <a class="nav-link text-dark" asp-controller="Matches" asp-action="Index">
						    <i class="bi bi-people me-2"></i><span class="sidebar-label">Applicants</span>
					    </a>
				    </li>
				    <li class="nav-item">
					    <a class="nav-link text-dark" asp-controller="CompanyRecommendations" asp-action="Index">
						    <i class="bi bi-bar-chart me-2"></i><span class="sidebar-label">Ranked Applicants</span>
					    </a>
				    </li>
				    <li class="nav-item">
					    <a class="nav-link text-dark" asp-controller="Chat" asp-action="Index">
						    <i class="bi bi-chat me-2"></i><span class="sidebar-label">Chat</span>
					    </a>
				    </li>
			    }
			    @if (isDeveloperMode)
			    {
				    <li class="nav-item">
					    <a class="nav-link text-dark" asp-controller="Developer" asp-action="Index">
						    <i class="bi bi-code-slash me-2"></i><span class="sidebar-label">Developer Hub</span>
					    </a>
				    </li>
			    }
		    </ul>

		    <hr/>

	    </div>

        <div class="flex-grow-1">
	        <div class="container">
		        <main role="main" class="pb-3 app-shell">
			        @RenderBody()
		        </main>
	        </div>
        </div>
    </div>

    <style>
            #sidebar.collapsed {
                width: 56px !important;
            }
            #sidebar.collapsed .sidebar-label,
            #sidebar.collapsed #sidebar-brand {
                display: none;
            }
            #sidebar.collapsed .nav-link {
                text-align: center;
                padding-left: 0;
                padding-right: 0;
            }
            #sidebar.collapsed .nav-link i {
                margin: 0 !important;
            }
            #sidebar {
                border-right: 1px solid #dee2e6;
            }
    </style>

    <script>
            const sidebar = document.getElementById('sidebar');
            const toggleBtn = document.getElementById('sidebar-toggle');
            const collapsed = localStorage.getItem('sidebarCollapsed') === 'true';
            if (collapsed) sidebar.classList.add('collapsed');
            toggleBtn.addEventListener('click', () => {
                sidebar.classList.toggle('collapsed');
                localStorage.setItem('sidebarCollapsed', sidebar.classList.contains('collapsed'));
            });
    </script>
    

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - PussyCats.Web - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
