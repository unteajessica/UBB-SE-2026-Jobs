@inject PussyCats.Web.Configuration.ApiConfiguration ApiConfiguration
@using PussyCats.Web.Infrastructure
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PussyCats.Web</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PussyCats.Web.styles.css" asp-append-version="true" />
</head>
<body class="pc-body">
    @{
        var selectedMode = Context.Session.GetString(SessionKeys.Mode);
        var isUserMode = string.Equals(selectedMode, AppModes.User, StringComparison.OrdinalIgnoreCase);
        var isCompanyMode = string.Equals(selectedMode, AppModes.Company, StringComparison.OrdinalIgnoreCase);
        var isDeveloperMode = string.Equals(selectedMode, AppModes.Developer, StringComparison.OrdinalIgnoreCase);
    }
    <header class="mb-4">
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm pc-nav px-3 py-2">
            <div class="container-fluid">
                        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        @if (isUserMode)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="UserProfile" asp-action="Index">Profile</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Documents" asp-action="Index">Documents</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="SkillTests" asp-action="Index">Skill Tests</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="PersonalityTest" asp-action="Index">Personality Test</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Preferences" asp-action="Index">Preferences</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Compatibility" asp-action="Index">Compatibility</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="UserStatus" asp-action="Index">My Applications</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Chat" asp-action="Index">Messages</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="JobBrowser" asp-action="Index">Browse Jobs</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="UserSkills" asp-action="Index" asp-route-userId="@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value">User Skills</a>
                            </li>
                        }
                        @if (isCompanyMode)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Company" asp-action="Profile" asp-route-id="@ApiConfiguration.TemporaryCompanyId">Company</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Matches" asp-action="Index">Applicants</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="CompanyRecommendations" asp-action="Index">Ranked Applicants</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Chat" asp-action="Index">Messages</a>
                            </li>
                        }
                        @if (isDeveloperMode)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Developer" asp-action="Index">Developer Hub</a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item d-flex align-items-center me-2">
                                <span class="nav-link text-dark fw-semibold">@User.Identity.Name</span>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-outline-secondary btn-sm">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            @if (isUserMode)
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Account" asp-action="Login">Login</a>
                                </li>
                            }
                        }
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="SwitchMode">Switch Mode</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3 app-shell">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - PussyCats.Web - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
