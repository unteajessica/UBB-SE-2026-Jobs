@model PussyCats.Library.Domain.SkillTest

@{
    ViewData["Title"] = "Edit Skill Test";
}

<div class="container mt-4">
    <h2>Edit Skill Test</h2>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="SkillTestId" />

                <div class="form-group mb-3">
                    <label asp-for="Name" class="control-label fw-bold"></label>
                    <input asp-for="Name" class="form-control" readonly />
                    <span class="form-text text-muted">Test names cannot be modified.</span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Score" class="control-label fw-bold"></label>
                    <input asp-for="Score" type="number" class="form-control" />
                    <span asp-validation-for="Score" class="text-danger"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="AchievedDate" class="control-label fw-bold"></label>
                    <input asp-for="AchievedDate" type="date" class="form-control" />
                    <span asp-validation-for="AchievedDate" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-warning">Update</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>