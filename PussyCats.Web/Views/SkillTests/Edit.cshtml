@model PussyCats.Library.Domain.SkillTest

@{
    ViewData["Title"] = "Edit Skill Test";
}

<section class="page-shell">
    <div class="form-card">
        <div class="form-card__header">
            <h2>Edit skill test</h2>
            <p>Update the score or date. Test names are locked after creation.</p>
        </div>
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="SkillTestId" />

            <div class="form-floating mb-3">
                <input asp-for="Name" class="form-control" placeholder="Name" readonly />
                <label asp-for="Name"></label>
                <span class="form-text text-muted">Test names cannot be modified.</span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Score" type="number" class="form-control" placeholder="Score" />
                <label asp-for="Score"></label>
                <span asp-validation-for="Score" class="text-danger"></span>
            </div>

            <div class="form-floating mb-4">
                <input asp-for="AchievedDate" type="date" class="form-control" placeholder="Achieved date" />
                <label asp-for="AchievedDate"></label>
                <span asp-validation-for="AchievedDate" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-dark">Update</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</section>
