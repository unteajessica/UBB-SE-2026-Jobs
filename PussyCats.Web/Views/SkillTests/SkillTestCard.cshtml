@model PussyCats.Library.Domain.SkillTest
@inject PussyCats.Library.Services.SkillTests.ISkillTestService SkillTestService

@{
    bool isRetakeEnabled = Model.SkillTestId > 0 && await SkillTestService.CanRetakeTestAsync(Model.SkillTestId);
    var badge = PussyCats.Library.Services.SimpleModelOperations.AssignTier(Model.Score);
    string dateFormatted = PussyCats.Library.Services.SkillTests.ISkillTestService.AchievedDateFormatted(Model);
    string tierLabel = badge?.Tier.ToString() ?? string.Empty;
    string tierColor = tierLabel switch
    {
        "Gold" => "#FFD700",
        "Silver" => "#C0C0C0",
        "Bronze" => "#CD7F32",
        _ => "#6c757d",
    };
}

<article class="skill-test-card">
    <div class="skill-test-card__media">
        <span class="skill-test-card__fallback fw-bold"
              style="color: @tierColor; font-size: 1.1rem;">@tierLabel</span>
    </div>
    <div class="skill-test-card__content">
        <div class="skill-test-card__meta">@dateFormatted</div>
        <h3 class="skill-test-card__title">@(string.IsNullOrEmpty(Model.Name) ? "Unknown" : Model.Name)</h3>
        <p class="skill-test-card__score">Score: <strong>@Model.Score%</strong></p>
    </div>
    <div class="skill-test-card__actions">
        <form asp-action="Retake" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.SkillTestId" />
            <button type="submit" class="btn btn-sm btn-dark" @(isRetakeEnabled ? string.Empty : "disabled")>
                @(isRetakeEnabled ? "Retake" : "Locked")
            </button>
        </form>
    </div>
</article>
