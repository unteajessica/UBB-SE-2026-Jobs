@model IEnumerable<PussyCats.Library.Domain.SkillTest>
@using PussyCats.Library.Services

@{
    ViewData["Title"] = "Skill Tests";
}

<style>
    body {
        background-color: #1F1F1F;
        color: #FFFFFF;
    }
</style>

<div class="container py-4">
    <div class="text-center mb-4">
        <h1 class="h3 fw-medium text-white">Skill Tests</h1>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show bg-success text-white border-0" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show bg-danger text-white border-0" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="d-flex flex-column gap-3 mx-auto" style="max-width: 650px;">
        @if (!Model.Any())
        {
            <div class="text-center p-4 rounded text-muted" style="background-color: #3D2E4D;">
                No skill tests recorded for your user profile.
            </div>
        }
        else
        {
            foreach (var test in Model)
            {
                // Pass each item into the separate reusable partial card template
                await Html.RenderPartialAsync("SkillTestCard", test);
            }
        }
    </div>
</div>