@model IEnumerable<PussyCats.Library.Domain.SkillTest>
@{
    ViewData["Title"] = "Skill Tests";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>My Skill Tests</h1>
        <a asp-action="Create" class="btn btn-primary">Create New Test</a>
    </div>

    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Test Name</th>
                <th>Score</th>
                <th>Achieved Date</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td><span class="badge bg-info text-dark">@item.Score</span></td>
                    <td>@item.AchievedDate.ToString("dd.MM.yyyy")</td>
                    <td class="text-center">
                        <a asp-action="Edit" asp-route-id="@item.SkillTestId" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Details" asp-route-id="@item.SkillTestId" class="btn btn-sm btn-info">Details</a>
                        <a asp-action="Delete" asp-route-id="@item.SkillTestId" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
