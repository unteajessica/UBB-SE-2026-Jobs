@model PussyCats.Library.Domain.SkillTest

@{
    ViewData["Title"] = "Skill Test Details";
}

<section class="page-shell">
    <div class="detail-card">
        <div class="detail-card__header">
            <div>
                <p class="eyebrow">Skill test</p>
                <h2>@Model.Name</h2>
            </div>
            <span class="score-pill">@Model.Score%</span>
        </div>
        <div class="detail-card__body">
            <div>
                <span class="detail-label">Achieved</span>
                <span class="detail-value">@Model.AchievedDate.ToString("dd.MM.yyyy")</span>
            </div>
            <div>
                <span class="detail-label">Status</span>
                <span class="detail-value">Recorded</span>
            </div>
        </div>
        <div class="detail-card__actions">
            <a asp-action="Edit" asp-route-id="@Model.SkillTestId" class="btn btn-dark">Edit test</a>
            <a asp-action="Index" class="btn btn-outline-secondary">Back to overview</a>
        </div>
    </div>
</section>
