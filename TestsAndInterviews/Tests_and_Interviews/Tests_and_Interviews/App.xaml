<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Tests_and_Interviews.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Tests_and_Interviews.Helpers">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:DateTimeToStringConverter x:Key="DateTimeToStringConverter"/>
            <converters:StatusConverter x:Key="StatusConverter"/>
            <converters:Base64ToImageSourceConverter x:Key="Base64ToImageSourceConverter"/>
            <converters:DurationToHeightConverter x:Key="DurationToHeightConverter"/>
            <converters:StatusToColorConverter x:Key="StatusToColorConverter"/>
            <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>

            <!-- Brushes -->
            <SolidColorBrush x:Key="AppPageBackgroundBrush" Color="#1E1E1E"/>
            <SolidColorBrush x:Key="AppSurfaceBrush" Color="#2D2D2D"/>
            <SolidColorBrush x:Key="AppBorderBrush" Color="#3F3F3F"/>
            <SolidColorBrush x:Key="AppSecondaryTextBrush" Color="#AAAAAA"/>

            <!-- Styles -->
            <Style x:Key="PageTitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="20"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="White"/>
            </Style>

            <Style x:Key="GhostBackButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Style>

            <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="#0078D4"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Padding" Value="16,8"/>
                <Setter Property="CornerRadius" Value="4"/>
            </Style>

            <Style x:Key="SecondaryActionButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="#3F3F3F"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Padding" Value="16,8"/>
                <Setter Property="CornerRadius" Value="4"/>
            </Style>

            <Style x:Key="AccentButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="#0078D4"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Padding" Value="16,8"/>
                <Setter Property="CornerRadius" Value="4"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>