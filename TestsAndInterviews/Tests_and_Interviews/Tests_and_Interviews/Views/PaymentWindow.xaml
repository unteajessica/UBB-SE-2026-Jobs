<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Tests_and_Interviews.Views.PaymentWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Tests_and_Interviews.Views"
    xmlns:models="using:Tests_and_Interviews.Models"
    Title="Payment &amp; Job Reports">

    <Grid Padding="32" Width="1000" VerticalAlignment="Center" HorizontalAlignment="Center" ColumnSpacing="40">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Spacing="16">
            <TextBlock Text="Payment Details" Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,8"/>

            <TextBox Header="Amount to Pay ($)" Text="{x:Bind ViewModel.AmountToPayText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <TextBox Header="Card Holder Name" Text="{x:Bind ViewModel.CardHolderName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <TextBox Header="Card Number" Text="{x:Bind ViewModel.CardNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="19" />

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Header="Expiration Date" Text="{x:Bind ViewModel.ExpDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="5"/>
                <TextBox Grid.Column="1" Header="CVV" Text="{x:Bind ViewModel.Cvv, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MaxLength="4"/>
            </Grid>

            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,16,0,0" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="100" Command="{x:Bind ViewModel.CancelCommand}"/>
                <Button Content="Pay" Width="100" Style="{ThemeResource AccentButtonStyle}" Command="{x:Bind ViewModel.PayCommand}"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Column="1" Spacing="16">
            <TextBlock Text="Highest Paid Jobs" Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,8"/>

            <StackPanel Orientation="Horizontal" Spacing="16">
                <ComboBox Header="Job Type" Width="150" SelectedItem="{x:Bind ViewModel.SelectedJobType, Mode=TwoWay}">
                    <x:String>Full-Time</x:String>
                    <x:String>Part-Time</x:String>
                    <x:String>Internship</x:String>
                </ComboBox>

                <ComboBox Header="Experience Level" Width="150" SelectedItem="{x:Bind ViewModel.SelectedExperienceLevel, Mode=TwoWay}">
                    <x:String>Junior</x:String>
                    <x:String>Mid-Level</x:String>
                    <x:String>Senior</x:String>
                </ComboBox>
            </StackPanel>

            <Grid Padding="12,8" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Company Name" FontWeight="Bold" />
                <TextBlock Grid.Column="1" Text="Job Title" FontWeight="Bold" />
                <TextBlock Grid.Column="2" Text="Amount ($)" FontWeight="Bold" HorizontalAlignment="Right" />
            </Grid>

            <ListView ItemsSource="{x:Bind ViewModel.PaymentData}" SelectionMode="None" Height="250" BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}" BorderThickness="1">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:JobPaymentInfo">
                        <Grid Padding="0,8" BorderBrush="{ThemeResource SystemControlBackgroundBaseLowBrush}" BorderThickness="0,0,0,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Bind CompanyName}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{x:Bind JobTitle}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{x:Bind AmountPayed}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </Grid>
</Window>