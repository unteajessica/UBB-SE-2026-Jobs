<Page
    x:Class="Tests_and_Interviews.Views.JobApplicantsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Tests_and_Interviews.Views"
    xmlns:models="using:Tests_and_Interviews.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
    </Page.Resources>

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header and Back Button -->
        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,20">
            <Button Content="&#xE72B;" 
                    FontFamily="Segoe Fluent Icons" 
                    Click="BackButton_Click"/>
            <TextBlock Text="Applicant List" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Applicants Table -->
        <ListView Grid.Row="1" 
                  ItemsSource="{x:Bind ViewModel.Applicants}" 
                  SelectedItem="{x:Bind ViewModel.SelectedApplicant, Mode=TwoWay}"
                  Visibility="{x:Bind ViewModel.TableVisibility, Mode=OneWay}"
                  SelectionChanged="ApplicantsList_SelectionChanged"
                  SelectionMode="Single">
            
            <!-- Table Header -->
            <ListView.HeaderTemplate>
                <DataTemplate>
                    <Grid Padding="10,5" BorderBrush="Gray" BorderThickness="0,0,0,1" Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Applicant Name" FontWeight="Bold"/>
                        <TextBlock Grid.Column="1" Text="Process Status" FontWeight="Bold"/>
                        <TextBlock Grid.Column="2" Text="Actions" FontWeight="Bold"/>
                    </Grid>
                </DataTemplate>
            </ListView.HeaderTemplate>

            <!-- Table Rows -->
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:Applicant">
                    <Grid Padding="10,10" BorderBrush="LightGray" BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="{x:Bind User.Name, FallbackValue='Unknown User'}" VerticalAlignment="Center"/>
                        
                        <TextBlock Grid.Column="1" Text="{x:Bind ApplicationStatus, Converter={StaticResource StatusConverter}}" VerticalAlignment="Center"/>
                        
                        <!-- Actions -->
                        <Button Grid.Column="2" 
                                Content="Remove" 
                                Click="RemoveApplicant_Click" 
                                Tag="{x:Bind}" 
                                VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Applicant Details Panel -->
        <StackPanel Grid.Row="2" Orientation="Vertical" Spacing="10" 
                    Visibility="{x:Bind ViewModel.DetailsVisibility, Mode=OneWay}" Padding="20">
            <TextBlock Text="Applicant Progress"/>

            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="Applicant Name: " VerticalAlignment="Center"/>
                <TextBlock Text="{x:Bind ViewModel.SelectedApplicant.User.Name, Mode=OneWay}" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="Applicant Email: " VerticalAlignment="Center"/>
                <TextBlock Text="{x:Bind ViewModel.SelectedApplicant.User.Email, Mode=OneWay}" VerticalAlignment="Center"/>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="Application status: " VerticalAlignment="Center"/>
                <ComboBox ItemsSource="{x:Bind ViewModel.ApplicationStatusOptions}" 
                          SelectedItem="{x:Bind ViewModel.DraftStatus, Mode=TwoWay}" 
                          Width="200"/>
                <Button Content="Send a status mail"
                        Click="SendStatusMail_Click"
                        VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Text="Grades" Margin="0,20,0,0"/>

            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="App Test Grade:" VerticalAlignment="Center" Width="150"/>
                <TextBox Text="{x:Bind ViewModel.DraftAppTestGrade, Mode=TwoWay}" Width="100"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="CV Grade:" VerticalAlignment="Center" Width="150"/>
                <TextBox Text="{x:Bind ViewModel.DraftCvGrade, Mode=TwoWay}" Width="100"/>
                <Button Content="Scan CV"
                        Click="ScanCv_Click"
                        IsEnabled="{x:Bind ViewModel.CanScanCv, Mode=OneWay}"
                        VerticalAlignment="Center"/>
                <TextBlock Text="{x:Bind ViewModel.CvScanErrorMessage, Mode=OneWay}"
                           Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                           VerticalAlignment="Center"
                           Visibility="{x:Bind ViewModel.CvScanErrorVisibility, Mode=OneWay}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="Company Test Grade:" VerticalAlignment="Center" Width="150"/>
                <TextBox Text="{x:Bind ViewModel.DraftCompanyTestGrade, Mode=TwoWay}" Width="100"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="Interview Grade:" VerticalAlignment="Center" Width="150"/>
                <TextBox Text="{x:Bind ViewModel.DraftInterviewGrade, Mode=TwoWay}" Width="100"/>
            </StackPanel>

            <Button Content="Save Changes" 
                    Click="SaveChanges_Click" 
                    Margin="0,20,0,0"/>
        </StackPanel>

    </Grid>
</Page>
