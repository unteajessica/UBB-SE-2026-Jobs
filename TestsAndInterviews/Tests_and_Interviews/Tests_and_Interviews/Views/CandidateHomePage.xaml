<Page
    x:Class="Tests_and_Interviews.Views.CandidateHomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Tests_and_Interviews.Helpers">

    <Page.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:DateTimeToStringConverter x:Key="DateTimeToStringConverter"/>
    </Page.Resources>


    <Grid x:Name="RootGrid" Padding="20" Background="#F8F7FF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <Button Grid.Row="0" Grid.ColumnSpan="2"
                Content="← Back to Menu"
                Click="BackButton_Click"
                Background="Transparent"
                Foreground="Black"
                BorderThickness="0"
                FontSize="16"
                Margin="0,0,0,16" />

        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="16">
            <TextBlock Text="Welcome back!" FontSize="28" FontWeight="Bold"/>

            <TextBlock Text="Companies matched with you"
                       FontSize="18"
                       Foreground="#6367FF"/>

            <ListView ItemsSource="{Binding MatchedCompanies}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="12"
                                Padding="16"
                                Margin="0,8"
                                Background="#FFDBFD">

                            <StackPanel Spacing="8">
                                <TextBlock Text="{Binding CompanyName}"
                                           FontSize="18"
                                           FontWeight="Bold"/>

                                <TextBlock Text="{Binding JobTitle}"
                                           FontSize="14"
                                           Foreground="#6367FF"/>

                                <Button Content="Schedule Interview"
                                        HorizontalAlignment="Right"
                                        Background="#6367FF"
                                        Foreground="White"
                                        CornerRadius="10"
                                        Padding="10,5"
                                        BorderThickness="0"
                                        Command="{Binding DataContext.ScheduleInterviewCommand, ElementName=RootGrid}"
                                        CommandParameter="{Binding}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>

        <StackPanel Grid.Row="1" Grid.Column="1"
                    Padding="20"
                    Spacing="12"
                    Visibility="{Binding IsBookingVisible, Converter={StaticResource BoolToVisibilityConverter}}">

            <TextBlock Text="Available Slots" FontSize="22" FontWeight="SemiBold"/>
            <TextBlock Text="{Binding SelectedCompany.CompanyName}" Foreground="#6367FF"/>

            <TextBlock Text="Select a day" FontSize="16"/>

            <StackPanel Orientation="Horizontal" Spacing="10">

                <Button Content="&lt;&lt;"
                        Background="#C9BEFF"
                        CornerRadius="8"
                        BorderThickness="0"
                        Command="{Binding LoadPreviousDaysCommand}"/>

                <ItemsControl ItemsSource="{Binding VisibleDays}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Margin="5"
                                    Padding="10"
                                    MinWidth="80"
                                    Background="{Binding BackgroundColor}"
                                    Foreground="{Binding ForegroundColor}"
                                    CornerRadius="10"
                                    BorderThickness="0"
                                    Command="{Binding DataContext.SelectDayForInterviewCommand, ElementName=RootGrid}"
                                    CommandParameter="{Binding}">

                                <TextBlock Text="{Binding DayFormatted}"/>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button Content="&gt;&gt;"
                        Background="#C9BEFF"
                        CornerRadius="8"
                        BorderThickness="0"
                        Command="{Binding LoadNextDaysCommand}"/>

            </StackPanel>

            <TextBlock Text="Available Hours" FontSize="16"/>

            <ItemsControl ItemsSource="{Binding AvailableSlots}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapGrid MaximumRowsOrColumns="3"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Margin="5"
                                Padding="10"
                                MinWidth="120"
                                Background="{Binding SlotColor}"
                                CornerRadius="10"
                                BorderThickness="0"
                                Command="{Binding DataContext.SelectSlotForInterviewCommand, ElementName=RootGrid}"
                                CommandParameter="{Binding}">

                            <TextBlock Text="{Binding TimeRange}"/>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button Content="Confirm Booking"
                    Margin="0,20,0,0"
                    HorizontalAlignment="Right"
                    Background="#6367FF"
                    Foreground="White"
                    CornerRadius="10"
                    Padding="12,6"
                    BorderThickness="0"
                    Command="{Binding ConfirmInterviewCommand}"/>

        </StackPanel>

        <StackPanel Grid.Row="1" Grid.Column="0"
                    Width="500"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Center"
                    Margin="15,0,0,20"
                    Spacing="8">
            <TextBlock Text="Your Interviews" FontSize="16" FontWeight="SemiBold"/>

            <ItemsControl ItemsSource="{Binding InterviewSessions}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="8" Padding="8" Margin="0,4" Background="White">
                            <StackPanel>
                                <TextBlock Text="{Binding DateStart, Converter={StaticResource DateTimeToStringConverter}}" FontSize="14"/>
                                <TextBlock Text="{Binding Status}" FontSize="12" Foreground="#6367FF"/>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,6,0,0">
                                    <Button Content="Join"
                                            Background="#6367FF"
                                            Foreground="White"
                                            CornerRadius="8"
                                            Padding="8,4"
                                            BorderThickness="0"
                                            Command="{Binding DataContext.JoinInterviewCommand, ElementName=RootGrid}"
                                            CommandParameter="{Binding}"/>

                                    <Button Content="Cancel"
                                            Background="#C9BEFF"
                                            Foreground="Black"
                                            CornerRadius="8"
                                            Padding="8,4"
                                            BorderThickness="0"
                                            Command="{Binding DataContext.CancelInterviewCommand, ElementName=RootGrid}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

    </Grid>
</Page>