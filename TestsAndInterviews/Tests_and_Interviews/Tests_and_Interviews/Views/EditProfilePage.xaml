<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Tests_and_Interviews.Views.EditProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="32" Spacing="20" MaxWidth="900" HorizontalAlignment="Stretch">

                <Button Content="Back" HorizontalAlignment="Left" Click="NavigateBack_Click" />

                <TextBlock Text="Edit company profile" FontSize="28" FontWeight="Bold" />

                <TextBlock Text="{Binding StatusMessage}" Foreground="{ThemeResource SystemFillColorCriticalBrush}" TextWrapping="Wrap"
                           IsTextSelectionEnabled="True" />

                <TextBlock Text="Required fields depend on your validators (name and logo are required)." Opacity="0.7" TextWrapping="Wrap" />

                <TextBlock Text="Basic details" FontSize="20" FontWeight="SemiBold" />
                <TextBox Header="Company name" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Header="About us" Text="{Binding AboutUs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True"
                         TextWrapping="Wrap" MinHeight="120" />
                <StackPanel>
                    <TextBlock Text="Profile picture (.jpg / .jpeg / .png path or URL)"/>
                    <Button Content="Attach image" Command="{x:Bind ViewModel.PickProfileImageCommand}" />
                    <Image
                        x:Name="PhotoPreviewImage"
                        Width="200"
                        Height="200"
                        Stretch="UniformToFill"
                        Margin="0,10,0,5" />
                    <TextBlock
                        x:Name="PhotoFileNameTextBlock"
                        FontSize="12"
                        Foreground="Gray"
                        Text="{x:Bind ViewModel.PhotoFileName, Mode=OneWay}" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Logo (.jpg / .jpeg / .png path or URL, required)"/>
                    <Button Content="Attach image" Command="{x:Bind ViewModel.PickLogoImageCommand}" />
                    <Image
                        x:Name="LogoPreviewImage"
                        Width="200"
                        Height="200"
                        Stretch="UniformToFill"
                        Margin="0,10,0,5" />
                    <TextBlock
                        x:Name="LogoFileNameTextBlock"
                        FontSize="12"
                        Foreground="Gray"
                        Text="{x:Bind ViewModel.LogoFileName, Mode=OneWay}" />
                </StackPanel>
                <TextBox Header="Location" Text="{Binding Location, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Header="Contact email" Text="{Binding Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="Create / Edit Game" FontSize="20" FontWeight="SemiBold" />

                <ComboBox
                    Header="Buddy id"
                    ItemsSource="{Binding editGame.AvailableBuddyIds}"
                    SelectedItem="{Binding editGame.SelectedBuddyId, Mode=TwoWay}" />

                <Image
                    Source="{Binding editGame.BuddyImagePath}"
                    Width="160"
                    Height="100"
                    Stretch="UniformToFill"
                    HorizontalAlignment="Left"
                    Margin="0,4,0,0" />

                <TextBox
                    Header="Coworker name"
                    Text="{Binding editGame.BuddyName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="Name" />

                <TextBox
                    Header="Buddy introduction"
                    Text="{Binding editGame.BuddyIntroduction, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="Introduction" />

                <TextBlock Text="Scenarios" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,0" />

                <ListView ItemsSource="{Binding editGame.Scenarios}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Spacing="10" Padding="10">
                                <TextBox
                                    Header="Scenario text"
                                    Text="{Binding ScenarioText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="Scenario description" />

                                <ListView ItemsSource="{Binding Choices}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Spacing="8" Margin="0,0,0,10">
                                                <TextBox
                                                    Header="Advice"
                                                    Text="{Binding Advice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    PlaceholderText="Advice text" />
                                                <TextBox
                                                    Header="Feedback"
                                                    Text="{Binding Feedback, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    PlaceholderText="Feedback text"
                                                    AcceptsReturn="True"
                                                    MinHeight="60" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <TextBox
                    Header="Conclusion"
                    Text="{Binding editGame.Conclusion, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    PlaceholderText="Conclusion text"
                    AcceptsReturn="True"
                    MinHeight="80" />

                <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,24,0,48">
                    <Button Content="Save" Style="{ThemeResource AccentButtonStyle}" Click="Save_Click" />
                    <Button Content="Cancel" Click="Cancel_Click" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>