<Page
    x:Class="Tests_and_Interviews.Views.RecruiterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewmodels="using:Tests_and_Interviews.ViewModels"
    xmlns:converters="using:Tests_and_Interviews.Helpers"
    Background="#C9BEFF">

	<Page.Resources>
		<converters:StatusToColorConverter x:Key="StatusToColorConverter"/>
		<converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
		<converters:DurationToHeightConverter x:Key="DurationToHeightConverter"/>
		<converters:DateTimeToStringConverter x:Key="DateTimeToStringConverter"/>
	</Page.Resources>

    <Grid Padding="60">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Button Grid.Row="0" Grid.ColumnSpan="2"
                Content="← Back to Menu"
                Click="BackButton_Click"
                Background="Transparent"
                Foreground="Black"
                BorderThickness="0"
                FontSize="16"
                Margin="0,0,0,20" />

        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="20">
            <TextBlock Text="Calendar Recrutor"
                       FontSize="35"
                       FontWeight="Bold"
                       Foreground="#6366FF"/>

            <CalendarView x:Name="MainCalendar"
                          SelectionMode="Single"
                          SelectedDatesChanged="MainCalendar_SelectedDatesChanged"/>

            <Button Content="Leaderboard Info"
                         Click="LeaderboardInfo_Click"
                         Background="#6366FF"
                         Foreground="White"
                         FontWeight="SemiBold"
                         FontSize="15"
                         Padding="20,12"
                         CornerRadius="10"
                         HorizontalAlignment="Left"/>

            <Border Background="White" CornerRadius="8" Padding="10" Margin="0,10,0,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                        <TextBlock Text="Pending Reviews" FontWeight="Bold" FontSize="16" Foreground="#111827" />
                        <Button Content="Refresh" Click="RefreshPendingReviews_Click" Margin="8,0,0,0" HorizontalAlignment="Right"/>
                    </StackPanel>

                    <ListView ItemsSource="{Binding PendingReviews}" SelectionMode="None" Height="200" BorderThickness="0">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="{Binding DateStart, Converter={StaticResource DateTimeToStringConverter}}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding Video}" TextTrimming="CharacterEllipsis" Margin="8,0" VerticalAlignment="Center" />

                                    <Button Grid.Column="2" Content="Review" Click="ReviewPending_Click" Tag="{Binding Id}" Margin="8,0,0,0" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>

        <Grid Grid.Row="1" Grid.Column="1" Margin="80,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="{Binding SelectedDateFormatted}"
                       FontSize="22"
                       Margin="0,0,0,20"/>

            <ListView Grid.Row="1"
                      ItemsSource="{Binding Slots}"
                      SelectionMode="None"
                      BorderThickness="0">

                <ListView.ItemTemplate>
                    <DataTemplate>

                        <Grid Height="{Binding Duration, Converter={StaticResource DurationToHeightConverter}}"
                              Tapped="Slot_Tapped">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding FormattedTime}"
                                       VerticalAlignment="Top"
                                       HorizontalAlignment="Center"
                                       Foreground="Black"
                                       Margin="0,10,0,0"/>

                            <Border Grid.Column="1"
                                    Margin="5"
                                    CornerRadius="8"
                                    Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}">

                                <TextBlock Text="Available"
                                           Foreground="White"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding InterviewType, Converter={StaticResource StringToVisibilityConverter}}"/>
                            </Border>

                        </Grid>

                    </DataTemplate>
                </ListView.ItemTemplate>

            </ListView>
        </Grid>
    </Grid>
</Page>