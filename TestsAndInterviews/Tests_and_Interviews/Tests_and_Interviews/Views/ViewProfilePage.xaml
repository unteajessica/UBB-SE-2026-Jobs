<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Tests_and_Interviews.Views.ViewProfilePage"
    x:Name="PageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Tests_and_Interviews.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:Tests_and_Interviews.Helpers"
    mc:Ignorable="d">

    <Page.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="32" Spacing="24" MaxWidth="1400" HorizontalAlignment="Stretch">

            <Button Content="← Back to Menu" 
                    Click="BackButton_Click" 
                    Background="Transparent" 
                    BorderThickness="0" 
                    FontSize="16" 
                    Margin="0,0,0,-12"/>

            <StackPanel>
                <Rectangle Width="1400" Height="100">
                    <Rectangle.Fill>
                        <ImageBrush x:Name="ProfilePictureBrush" Stretch="Fill"/>
                    </Rectangle.Fill>
                </Rectangle>

                <TextBlock x:Name="ProfilePictureHintText"
                               Text="{x:Bind ViewModel.ProfilePictureHintText, Mode=OneWay}"
                               TextWrapping="Wrap"
                               MaxWidth="120"
                               FontSize="10"
                               Opacity="0.7" />

            </StackPanel>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="4">

                    <Ellipse Width="80" Height="80" StrokeThickness="1" Stroke="{ThemeResource CardStrokeColorDefaultBrush}">
                        <Ellipse.Fill>
                            <ImageBrush x:Name="CompanyLogoBrush" Stretch="UniformToFill" />
                        </Ellipse.Fill>
                    </Ellipse>

                    <TextBlock x:Name="CompanyLogoHintText"
                               Text="{x:Bind ViewModel.CompanyLogoHintText, Mode=OneWay}"
                               TextWrapping="Wrap"
                               MaxWidth="120"
                               FontSize="10"
                               Opacity="0.7" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="24,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Company.Name}" FontSize="32" FontWeight="Bold" />
                    <TextBlock Text="{Binding LoadMessage}" Foreground="{ThemeResource SystemFillColorCriticalBrush}" FontSize="14" TextWrapping="Wrap" />
                </StackPanel>

                <Button Grid.Column="2"
                        Content="Edit profile"
                        VerticalAlignment="Center"
                        Command="{Binding EditProfileCommand}" />
            </Grid>

            <Border Padding="16" CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <TextBlock Text="{Binding ApplicantSummary}" FontWeight="SemiBold" TextWrapping="Wrap" />
            </Border>

            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="8">
                        <TextBlock FontWeight="Bold" FontSize="18">
                            <Run Text="{Binding CompletedTasksCount}" />
                            <Run Text="/5 completed" />
                        </TextBlock>
                        <ProgressBar Value="{Binding CompletionPercentage}" Maximum="100" Height="8" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="32,0,0,0">
                        <TextBlock Text="Remaining tasks:" FontWeight="SemiBold" />
                        <ItemsControl ItemsSource="{Binding RemainingTasks}" Margin="0,8,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Margin="0,2,0,0" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0" Spacing="24">

                    <StackPanel Spacing="12">
                        <TextBlock Text="About us" FontSize="20" FontWeight="Bold" />
                        <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" MinHeight="480" Padding="16">
                            <TextBlock Text="{Binding Company.AboutUs}" TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>

                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="24">
                        <StackPanel Spacing="12">
                            <Grid>
                                <TextBlock Text="Collaborators" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding Top3CollabsPreviews}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:CompanyCollabListRow">
                                        <StackPanel Margin="0,0,0,12" Spacing="4">
                                            <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Content="See all >" Command="{x:Bind ViewModel.SeeAllCollaboratorsCommand}" Style="{ThemeResource AccentButtonStyle}" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="12,0,0,0" Spacing="24">
                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="24">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Trending skills" FontSize="20" FontWeight="Bold" />
                            <ItemsControl ItemsSource="{Binding TrendingSkills}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:CompanyTrendingSkillRow">
                                        <StackPanel Margin="0,0,0,16" Spacing="4">
                                            <TextBlock FontWeight="SemiBold">
                            <Run Text="{x:Bind Rank}" /><Run Text=". " /><Run Text="{x:Bind SkillName}" />
                                            </TextBlock>
                                            <TextBlock Text="{x:Bind Detail}" FontSize="12" Opacity="0.8" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="24">
                        <StackPanel Spacing="12">
                            <Grid>
                                <TextBlock Text="Jobs" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding Top3JobPreviews}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:CompanyProfileListRow">
                                        <StackPanel Margin="0,0,0,12" Spacing="4">
                                            <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold" />
                                            <TextBlock Text="{x:Bind Subtitle}" TextWrapping="Wrap" Opacity="0.85" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Content="See all >" Command="{x:Bind ViewModel.SeeAllJobsCommand}" Style="{ThemeResource AccentButtonStyle}" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>

                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="24">
                        <StackPanel Spacing="12">
                            <Grid>
                                <TextBlock Text="Events" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding Top3EventPreviews}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:CompanyProfileListRow">
                                        <StackPanel Margin="0,0,0,12" Spacing="4">
                                            <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold" />
                                            <TextBlock Text="{x:Bind Subtitle}" TextWrapping="Wrap" Opacity="0.85" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Content="See all >" Command="{x:Bind ViewModel.SeeAllEventsCommand}" Style="{ThemeResource AccentButtonStyle}" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <StackPanel>
                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="12" Padding="24">
                    <StackPanel Spacing="8">
                        <StackPanel Padding="40" Spacing="25" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <StackPanel Visibility="{Binding IncompleteGame, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock>Game not completed</TextBlock>
                            </StackPanel>

                            <StackPanel Visibility="{Binding IsStartVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Image
                                    Source="{Binding BuddyImagePath}"
                                    Width="230"
                                    Height="140"
                                    Stretch="UniformToFill"
                                    HorizontalAlignment="Left"
                                    Margin="0,4,0,0" />
                                <TextBlock Text="{Binding WelcomeMessage, Mode=OneWay}" 
                                    FontSize="28" FontWeight="Bold" Foreground="{ThemeResource SystemAccentColor}" 
                                    TextAlignment="Center" Margin="0,0,0,20"/>
                                <Button Content="Start" Command="{Binding StartGameCommand}" HorizontalAlignment="Center" Padding="20,10"/>
                            </StackPanel>

                            <StackPanel Visibility="{Binding IsChoiceActive, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Image
                                    Source="{Binding BuddyImagePath}"
                                    Width="230"
                                    Height="140"
                                    Stretch="UniformToFill"
                                    HorizontalAlignment="Left"
                                    Margin="0,4,0,0" />
                                <TextBlock Text="{Binding CurrentQuestion, Mode=OneWay}" 
                                    FontSize="18" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="500" Margin="0,0,0,20"/>

                                <ItemsControl ItemsSource="{Binding CurrentChoices, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Button Content="{Binding}" Margin="0,5,0,5" HorizontalAlignment="Stretch"
                                                Command="{Binding ElementName=PageRoot, Path=ViewModel.SelectChoiceCommand}"
                                                CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <StackPanel Visibility="{Binding IsReactionActive, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" Spacing="20">
                                <Image
                                    Source="{Binding BuddyImagePath}"
                                    Width="230"
                                    Height="140"
                                    Stretch="UniformToFill"
                                    HorizontalAlignment="Left"
                                    Margin="0,4,0,0" />
                                <TextBlock Text="Reaction:" FontSize="14" Foreground="Gray" TextAlignment="Center"/>
                                <TextBlock Text="{Binding Feedback, Mode=OneWay}" 
                                    FontSize="20" FontStyle="Italic" Foreground="LightGreen" 
                                    TextAlignment="Center" TextWrapping="Wrap" MaxWidth="450"/>
                                <Button Content="Continue" Command="{Binding GoToNextStepCommand}" HorizontalAlignment="Center" Style="{StaticResource AccentButtonStyle}"/>
                            </StackPanel>

                            <StackPanel Visibility="{Binding IsConclusionVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="Conclusion" FontSize="28" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,20"/>
                                <TextBlock Text="{Binding Feedback, Mode=OneWay}" FontSize="18" TextAlignment="Center" MaxWidth="500"/>
                                <Button Content="Again" Command="{Binding RetryGameCommand}" HorizontalAlignment="Center" Margin="0,30,0,0"/>
                            </StackPanel>

                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>