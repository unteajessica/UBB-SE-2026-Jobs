@model float

@{
    ViewData["Title"] = "Test Results";
}

<div class="container mt-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-body py-5">
                    <i class="bi bi-check-circle text-success" style="font-size: 4rem;"></i>
                    <h2 class="mt-3 fw-bold">Test Submitted Successfully!</h2>
                    <p class="text-muted fs-5">Your final score has been calculated by the system.</p>

                    <div class="display-1 fw-bold text-primary my-4">
                        @Model.ToString("0.##") / @ViewBag.MaxScore.ToString("0.##")
                    </div>

                    <a asp-controller="Tests" asp-action="Index" class="btn btn-outline-secondary mt-3">
                        Return to Dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>