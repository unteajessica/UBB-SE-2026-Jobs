@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center mt-5">
    <h1 class="display-3 fw-bold mb-4">Welcome to Tests & Interviews Platform</h1>
    <p class="lead mb-5">Your complete solution for managing job applications, technical assessments, and interviews</p>
</div>

<div class="row mt-5">
    <div class="col-md-6 col-lg-3 mb-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body text-center">
                <h5 class="card-title">Jobs</h5>
                <p class="card-text">Browse available positions and submit your applications</p>
            </div>
        </div>
    </div>
    
    <div class="col-md-6 col-lg-3 mb-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body text-center">
                <h5 class="card-title">Tests</h5>
                <p class="card-text">Take technical assessments and track your results</p>
            </div>
        </div>
    </div>
    
    <div class="col-md-6 col-lg-3 mb-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body text-center">
                <h5 class="card-title">Events</h5>
                <p class="card-text">View upcoming recruitment events and sessions</p>
            </div>
        </div>
    </div>
    
    <div class="col-md-6 col-lg-3 mb-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body text-center">
                <h5 class="card-title">Interviews</h5>
                <p class="card-text">Schedule and manage your interview appointments</p>
            </div>
        </div>
    </div>
</div>

<div class="row mt-5">
    <div class="col-lg-8 mx-auto">
        <div class="alert alert-info" role="alert">
            <h4 class="alert-heading">How it works</h4>
            <hr>
            <p class="mb-0">
                <strong>For Candidates:</strong> Browse job openings, take required tests, book interview slots, and track your application progress.<br>
                <strong>For Recruiters:</strong> Post jobs, create assessments, review candidate results, and manage the entire hiring workflow.
            </p>
        </div>
    </div>
</div>