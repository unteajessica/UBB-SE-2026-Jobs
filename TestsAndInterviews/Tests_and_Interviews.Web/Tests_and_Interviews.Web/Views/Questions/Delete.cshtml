@model Tests_and_Interviews.Web.Dtos.QuestionDto

@{
    ViewData["Title"] = "Delete Question";
}

<div class="container mt-4">
    <h2 class="fw-bold mb-3">Delete Question</h2>

    <div class="card p-4 shadow-sm">
        <dl class="row">
            <dt class="col-sm-3">Question</dt>
            <dd class="col-sm-9">@Model.QuestionText</dd>

            <dt class="col-sm-3">Type</dt>
            <dd class="col-sm-9">@Model.QuestionType</dd>

            <dt class="col-sm-3">Score</dt>
            <dd class="col-sm-9">@Model.QuestionScore</dd>
        </dl>

        <form asp-action="DeleteConfirmed" method="post">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Confirm Delete</button>
            <a asp-action="Index" asp-route-testId="@Model.TestId" class="btn btn-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>
