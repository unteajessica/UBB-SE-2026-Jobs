@using Tests_and_Interviews_API.Dtos
@model JobPostingDto

@{
    ViewData["Title"] = "Post a New Job";
    var skills = ViewBag.Skills as List<SkillDto> ?? new List<SkillDto>();
}

<div class="mb-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">&larr; Back to Jobs</a>
</div>

<h1>Post a New Job</h1>

<div class="card shadow-sm mt-3">
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="JobTitle" class="form-label">Job Title</label>
                    <input asp-for="JobTitle" class="form-control" placeholder="e.g. Software Engineer" />
                    <span asp-validation-for="JobTitle" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="IndustryField" class="form-label">Industry Field</label>
                    <select asp-for="IndustryField" class="form-select">
                        <option value="">-- Select Industry --</option>
                        <option>IT</option>
                        <option>Business</option>
                        <option>Healthcare</option>
                        <option>Education</option>
                        <option>Finance</option>
                        <option>Other</option>
                    </select>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="JobType" class="form-label">Job Type</label>
                    <select asp-for="JobType" class="form-select">
                        <option value="">-- Select Type --</option>
                        <option>Full-time</option>
                        <option>Part-time</option>
                        <option>Internship</option>
                        <option>Remote</option>
                        <option>Hybrid</option>
                    </select>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="ExperienceLevel" class="form-label">Experience Level</label>
                    <select asp-for="ExperienceLevel" class="form-select">
                        <option value="">-- Select Level --</option>
                        <option>Internship</option>
                        <option>Entry Level</option>
                        <option>Mid-Senior Level</option>
                        <option>Director</option>
                        <option>Executive</option>
                    </select>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="JobLocation" class="form-label">Location</label>
                    <input asp-for="JobLocation" class="form-control" placeholder="e.g. Cluj-Napoca" />
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="AvailablePositions" class="form-label">Available Positions</label>
                    <input asp-for="AvailablePositions" type="number" min="1" class="form-control" />
                </div>
                <div class="col-md-3 mb-3">
                    <label asp-for="Salary" class="form-label">Salary (RON)</label>
                    <input asp-for="Salary" type="number" min="0" class="form-control" />
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="StartDate" class="form-label">Start Date</label>
                    <input asp-for="StartDate" type="date" class="form-control" />
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="EndDate" class="form-label">End Date</label>
                    <input asp-for="EndDate" type="date" class="form-control" />
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Deadline" class="form-label">Application Deadline</label>
                    <input asp-for="Deadline" type="date" class="form-control" />
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="JobDescription" class="form-label">Job Description</label>
                <textarea asp-for="JobDescription" class="form-control" rows="5"
                          placeholder="Describe the role, responsibilities and requirements..."></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label">Required Skills</label>
                <div class="card p-3">
                    @if (skills.Any())
                    {
                        <div class="row">
                            @foreach (var skill in skills)
                            {
                                <div class="col-md-6 mb-3">
                                    <div class="form-check">
                                        <input class="form-check-input skill-checkbox" type="checkbox" 
                                               id="skill_@skill.SkillId" 
                                               data-skill-id="@skill.SkillId" />
                                        <label class="form-check-label" for="skill_@skill.SkillId">
                                            @skill.SkillName
                                        </label>
                                    </div>
                                    <div class="mt-2" style="display:none;" id="percentage_@skill.SkillId">
                                        <label for="percentage_input_@skill.SkillId" class="form-label form-label-sm">
                                            Required Knowledge %
                                        </label>
                                        <input type="number" 
                                               min="1" 
                                               max="100" 
                                               value="50"
                                               class="form-control form-control-sm"
                                               id="percentage_input_@skill.SkillId"
                                               data-percentage-for="@skill.SkillId" />
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No skills available.</p>
                    }
                </div>
            </div>

            <input type="hidden" asp-for="CompanyId" />

            <div class="d-flex justify-content-end gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                <button type="submit" class="btn btn-primary">Post Job</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const skillCheckboxes = document.querySelectorAll('.skill-checkbox');
            let skillIndex = 0;

            skillCheckboxes.forEach(checkbox => {
                checkbox.addEventListener('change', function () {
                    const skillId = this.getAttribute('data-skill-id');
                    const percentageDiv = document.getElementById('percentage_' + skillId);

                    if (this.checked) {
                        percentageDiv.style.display = 'block';
                    } else {
                        percentageDiv.style.display = 'none';
                    }
                });
            });

            // Handle form submission - populate hidden fields with selected skills
            const form = document.querySelector('form');
            if (form) {
                form.addEventListener('submit', function (e) {
                    const checkedSkills = document.querySelectorAll('.skill-checkbox:checked');
                    let indexCounter = 0;

                    // Clear any existing JobSkills data
                    const existingInputs = form.querySelectorAll('input[name^="JobSkills"]');
                    existingInputs.forEach(input => input.remove());

                    // Create new hidden inputs for each checked skill
                    checkedSkills.forEach(checkbox => {
                        const skillId = checkbox.getAttribute('data-skill-id');
                        const percentage = document.getElementById('percentage_input_' + skillId).value;

                        // Add Index
                        const indexInput = document.createElement('input');
                        indexInput.type = 'hidden';
                        indexInput.name = 'JobSkills.Index';
                        indexInput.value = indexCounter;
                        form.appendChild(indexInput);

                        // Add SkillId
                        const skillInput = document.createElement('input');
                        skillInput.type = 'hidden';
                        skillInput.name = 'JobSkills[' + indexCounter + '].SkillId';
                        skillInput.value = skillId;
                        form.appendChild(skillInput);

                        // Add JobId (always 0 for new jobs)
                        const jobIdInput = document.createElement('input');
                        jobIdInput.type = 'hidden';
                        jobIdInput.name = 'JobSkills[' + indexCounter + '].JobId';
                        jobIdInput.value = '0';
                        form.appendChild(jobIdInput);

                        // Add RequiredPercentage
                        const percentageInput = document.createElement('input');
                        percentageInput.type = 'hidden';
                        percentageInput.name = 'JobSkills[' + indexCounter + '].RequiredPercentage';
                        percentageInput.value = percentage;
                        form.appendChild(percentageInput);

                        indexCounter++;
                    });
                });
            }
        });
    </script>
}
