@using Tests_and_Interviews_API.Dtos
@model JobPostingDto

@{
    ViewData["Title"] = Model.JobTitle ?? "Job Details";
}

<div class="mb-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">&larr; Back to Jobs</a>
</div>

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h2 class="mb-0">@Model.JobTitle</h2>
        @if (User.IsInRole("Recruiter"))
        {
            <div>
                <a asp-action="Edit" asp-route-id="@Model.JobId"
                   class="btn btn-outline-secondary btn-sm">Edit</a>
                <a asp-action="Delete" asp-route-id="@Model.JobId"
                   class="btn btn-outline-danger btn-sm">Delete</a>
            </div>
        }
    </div>
    <div class="card-body">
        <div class="row mb-4">
            <div class="col-md-6">
                <h5 class="text-muted">Job Details</h5>
                <table class="table table-borderless table-sm">
                    <tr><th>Industry</th><td>@(Model.IndustryField ?? "—")</td></tr>
                    <tr><th>Type</th><td>@(Model.JobType ?? "—")</td></tr>
                    <tr><th>Experience Level</th><td>@(Model.ExperienceLevel ?? "—")</td></tr>
                    <tr><th>Location</th><td>@(Model.JobLocation ?? "—")</td></tr>
                    <tr><th>Available Positions</th><td>@Model.AvailablePositions</td></tr>
                </table>
            </div>
            <div class="col-md-6">
                <h5 class="text-muted">Dates & Salary</h5>
                <table class="table table-borderless table-sm">
                    <tr><th>Start Date</th><td>@(Model.StartDate?.ToString("dd MMM yyyy") ?? "—")</td></tr>
                    <tr><th>End Date</th><td>@(Model.EndDate?.ToString("dd MMM yyyy") ?? "—")</td></tr>
                    <tr><th>Deadline</th><td>@(Model.Deadline?.ToString("dd MMM yyyy") ?? "—")</td></tr>
                    <tr><th>Posted At</th><td>@(Model.PostedAt?.ToString("dd MMM yyyy") ?? "—")</td></tr>
                    @if (Model.Salary.HasValue)
                    {
                        <tr><th>Salary</th><td>@Model.Salary.Value.ToString("N0") RON</td></tr>
                    }
                </table>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.JobDescription))
        {
            <h5 class="text-muted">Description</h5>
            <p>@Model.JobDescription</p>
        }

        @if (Model.JobSkills != null && Model.JobSkills.Any())
        {
            <h5 class="text-muted mt-3">Required Skills</h5>
            <div class="row">
                @foreach (var skill in Model.JobSkills)
                {
                    <div class="col-md-4 mb-2">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span>@(skill.SkillDto?.SkillName ?? $"Skill #{skill.SkillId}")</span>
                            <span class="badge bg-primary">@skill.RequiredPercentage%</span>
                        </div>
                        <div class="progress" style="height: 8px;">
                            <div class="progress-bar" role="progressbar"
                                 style="width: @skill.RequiredPercentage%"
                                 aria-valuenow="@skill.RequiredPercentage"
                                 aria-valuemin="0" aria-valuemax="100">
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
    <div class="card-footer d-flex justify-content-between">
        <div>
            @if (User.IsInRole("Candidate"))
            {
                <a asp-controller="Applicants" asp-action="Apply" asp-route-jobId="@Model.JobId"
                   class="btn btn-success">Apply Now</a>
            }
            @if (User.IsInRole("Recruiter"))
            {
                <a asp-controller="Applicants" asp-action="ApplicantsByJob" asp-route-jobId="@Model.JobId"
                   class="btn btn-info">View Applicants</a>
            }
        </div>
    </div>
</div>
