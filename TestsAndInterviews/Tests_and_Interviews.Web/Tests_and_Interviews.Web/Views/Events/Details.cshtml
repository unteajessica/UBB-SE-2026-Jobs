@model Tests_and_Interviews.Web.Dtos.EventDto

@{
    ViewData["Title"] = Model.Title;
}

<h2>@Model.Title</h2>

<div class="card">
    <div class="card-body">
        <p><strong>Location:</strong> @Model.Location</p>
        <p><strong>Start Date:</strong> @Model.StartDate.ToShortDateString()</p>
        <p><strong>End Date:</strong> @Model.EndDate.ToShortDateString()</p>
        <p><strong>Description:</strong> @Model.Description</p>
        <p><strong>Posted At:</strong> @Model.PostedAt</p>
    </div>
</div>

<h4 class="mt-4">Collaborators</h4>
@{
    var collaborators = ViewBag.Collaborators as List<Tests_and_Interviews.Web.Dtos.CollaboratorDto> ?? new List<Tests_and_Interviews.Web.Dtos.CollaboratorDto>();
}
@if (!collaborators.Any())
{
    <p>No collaborators for this event.</p>
}
else
{
    <ul>
        @foreach (var c in collaborators)
        {
            <li>@c.CompanyName</li>
        }
    </ul>
}

<a asp-action="Index" class="btn btn-secondary mt-3">Back to Events</a>