@using PussyCats.Web.Dtos
@model List<ApplicantDto>

@{
    ViewData["Title"] = "Applicants";
    var job = ViewBag.Job as JobPostingDto;
}

<div class="mb-3">
    <a asp-action="Details" asp-controller="Jobs" asp-route-id="@job?.JobId" class="btn btn-outline-secondary btn-sm">&larr; Back to Job</a>
</div>

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <div>
            <h2 class="mb-0">Applicants for: @job?.JobTitle</h2>
            <small class="text-muted">@(Model?.Count ?? 0) application@((Model?.Count ?? 0) != 1 ? "s" : "")</small>
        </div>
    </div>
    <div class="card-body">
        @if (Model == null || Model.Count == 0)
        {
            <div class="alert alert-info">
                <p class="mb-0">No applications have been received for this job yet.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>User ID</th>
                            <th>Applied Date</th>
                            <th>Application Status</th>
                            <th>App Test</th>
                            <th>CV Grade</th>
                            <th>Company Test</th>
                            <th>Interview</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var applicant in Model)
                        {
                            <tr>
                                <td>@applicant.UserId</td>
                                <td>@applicant.AppliedAt.ToString("dd MMM yyyy HH:mm")</td>
                                <td>
                                    @if (string.IsNullOrEmpty(applicant.ApplicationStatus))
                                    {
                                        <span class="badge bg-secondary">Pending</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info">@applicant.ApplicationStatus</span>
                                    }
                                </td>
                                <td>
                                    @if (applicant.AppTestGrade.HasValue)
                                    {
                                        <span>@applicant.AppTestGrade.Value.ToString("F2")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">â€”</span>
                                    }
                                </td>
                                <td>
                                    @if (applicant.CvGrade.HasValue)
                                    {
                                        <span>@applicant.CvGrade.Value.ToString("F2")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">â€”</span>
                                    }
                                </td>
                                <td>
                                    @if (applicant.CompanyTestGrade.HasValue)
                                    {
                                        <span>@applicant.CompanyTestGrade.Value.ToString("F2")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">â€”</span>
                                    }
                                </td>
                                <td>
                                    @if (applicant.InterviewGrade.HasValue)
                                    {
                                        <span>@applicant.InterviewGrade.Value.ToString("F2")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">â€”</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

