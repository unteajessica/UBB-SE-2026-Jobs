@model PussyCats.Library.Domain.SkillTest

@{
    ViewData["Title"] = "Create Skill Test";
}

<section class="page-shell">
    <div class="form-card">
        <div class="form-card__header">
            <h2>Create skill test</h2>
            <p>Record a new test score and achievement date.</p>
        </div>
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-floating mb-3">
                <input asp-for="Name" class="form-control" placeholder="Skill Test Name" />
                <label asp-for="Name"></label>
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Score" type="number" class="form-control" placeholder="Score" />
                <label asp-for="Score"></label>
                <span asp-validation-for="Score" class="text-danger"></span>
            </div>

            <div class="form-floating mb-4">
                <input asp-for="AchievedDate" type="date" class="form-control" placeholder="Achieved date" />
                <label asp-for="AchievedDate"></label>
                <span asp-validation-for="AchievedDate" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-dark">Save</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Back to list</a>
            </div>
        </form>
    </div>
</section>
