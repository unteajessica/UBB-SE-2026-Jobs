@model PussyCats.Library.DTOs.UserApplicationResult
@{
    ViewData["Title"] = "Applicant Details";
}

<h1>Applicant Details</h1>

<dl class="row">
    <dt class="col-sm-3">Applicant</dt>
    <dd class="col-sm-9">@Model.User.Name</dd>

    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.User.Email</dd>

    <dt class="col-sm-3">Job</dt>
    <dd class="col-sm-9">@Model.Job.JobTitle</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Match.Status</dd>

    <dt class="col-sm-3">Score</dt>
    <dd class="col-sm-9">@Model.CompatibilityScore</dd>

    <dt class="col-sm-3">Feedback</dt>
    <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Feedback) ? "-" : Model.Feedback)</dd>
</dl>

<a class="btn btn-secondary" asp-action="Index">Back</a>
<a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Match.MatchId">Edit Decision</a>
