@model PussyCats.Library.DTOs.UserApplicationResult
@{
    ViewData["Title"] = "Delete";
}

<h1>Delete</h1>

<div class="alert alert-warning">
    Removing a company status entry is not supported. This view is read-only.
</div>

<dl class="row">
    <dt class="col-sm-3">Applicant</dt>
    <dd class="col-sm-9">@Model.User.Name</dd>

    <dt class="col-sm-3">Job</dt>
    <dd class="col-sm-9">@Model.Job.JobTitle</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Match.Status</dd>
</dl>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-danger" disabled>Delete</button>
    <a class="btn btn-secondary" asp-action="Index">Back</a>
</form>
