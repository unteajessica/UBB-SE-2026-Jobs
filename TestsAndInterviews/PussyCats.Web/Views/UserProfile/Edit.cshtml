@model User

@{
    ViewData["Title"] = "Edit Profile";
}

<h2>Edit Profile</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

<input type="hidden" asp-for="UserId" id="UserId" />
<div class="card mb-4 p-3">
    <h4>Upload CV for Auto-Population</h4>

    <div class="row">
        <div class="col-md-8">
            <input type="file"
                   id="cvFileInput"
                   class="form-control"
                   accept=".json,.xml" />
        </div>

        <div class="col-md-4">
            <button type="button"
                    class="btn btn-primary"
                    id="uploadCvBtn">
                Upload CV
            </button>
        </div>
    </div>

    <div id="cvUploadMessage"
         class="mt-3 text-success">
    </div>
</div>

<form asp-action="Edit" method="post">

    <div class="row">
        <div class="col-md-6">
            <label>First Name</label>
            <input asp-for="FirstName" class="form-control" />
        </div>

        <div class="col-md-6">
            <label>Last Name</label>
            <input asp-for="LastName" class="form-control" />
        </div>
    </div>

    <div class="row mt-3">
        <div class="col-md-6">
            <label>Age</label>
            <input asp-for="Age" type="number" class="form-control" />
        </div>

        <div class="col-md-6">
            <label>Gender</label>

            <select asp-for="Gender" class="form-select">
                <option value="">Select Gender</option>
                <option>Male</option>
                <option>Female</option>
            </select>
        </div>
    </div>

    <div class="row mt-3">
        <div class="col-md-6">
            <label>Email</label>
            <input asp-for="Email" class="form-control" />
        </div>

        <div class="col-md-6">
            <label>Phone</label>
            <input asp-for="Phone" class="form-control" />
        </div>
    </div>

    <div class="row mt-3">
        <div class="col-md-6">
            <label>GitHub</label>
            <input asp-for="GitHub" class="form-control" />
        </div>

        <div class="col-md-6">
            <label>LinkedIn</label>
            <input asp-for="LinkedIn" class="form-control" />
        </div>
    </div>

    <div class="row mt-3">
        <div class="col-md-6">
            <label>Country</label>
            <input asp-for="Country" class="form-control" />
        </div>

        <div class="col-md-6">
            <label>City</label>
            <input asp-for="City" class="form-control" />
        </div>
    </div>

    <div class="mt-3">
        <label>University</label>
        <input asp-for="University" class="form-control" />
    </div>

    <div class="mt-3">
        <label>Expected Graduation Year</label>

        <select asp-for="ExpectedGraduationYear" class="form-select">
            @for (int year = DateTime.Now.Year; year <= DateTime.Now.Year + 10; year++)
            {
                <option value="@year">@year</option>
            }
        </select>
    </div>

    <div class="mt-3">
        <label>Address</label>
        <textarea asp-for="Address" class="form-control"></textarea>
    </div>

    <div class="form-check mt-3">
        <input asp-for="HasDisabilities" class="form-check-input" />
        <label asp-for="HasDisabilities" class="form-check-label">
            Disabilities
        </label>
    </div>

    <hr />

    <label>Skills</label>

    <input type="text"
           id="skill-input"
           class="form-control"
           list="skill-suggestions" />

    <datalist id="skill-suggestions">
        <option value="C#"/>
        <option value=".NET"/>
        <option value="ASP.NET Core"/>
        <option value="React"/>
        <option value="Angular"/>
        <option value="Docker"/>
        <option value="Azure"/>
    </datalist>

    <button type="button"
            class="btn btn-secondary mt-2"
            onclick="addSkill()">
        Add Skill
    </button>

    <div id="skills-container" class="mt-3">

        @for (int i = 0; i < Model.Skills.Count; i++)
        {
            <div class="badge bg-primary p-2 me-2 mb-2 skill-item">

                @Model.Skills[i].Skill?.Name

                <button type="button"
                        class="btn-close btn-close-white ms-2"
                        onclick="removeSkill(this)">
                </button>

                <input type="hidden"
                       name="Skills[@i].Skill.Name"
                       value="@Model.Skills[i].Skill?.Name" />

            </div>
        }

    </div>

    <hr />

    <h4>Work Experience</h4>

    <div id="workExperienceContainer">

        @for (int i = 0; i < Model.WorkExperiences.Count; i++)
        {
            <div class="card p-3 mb-3 work-item">

                <div class="row mb-2">

                    <div class="col-md-5">
                        <input name="WorkExperiences[@i].Company"
                               value="@Model.WorkExperiences[i].Company"
                               class="form-control"
                               placeholder="Company" />
                    </div>

                    <div class="col-md-5">
                        <input name="WorkExperiences[@i].JobTitle"
                               value="@Model.WorkExperiences[i].JobTitle"
                               class="form-control"
                               placeholder="Job Title" />
                    </div>

                    <div class="col-md-2">
                        <button type="button"
                                class="btn btn-danger w-100"
                                onclick="removeItem(this)">
                            Remove
                        </button>
                    </div>

                </div>

                <div class="row mb-2">

                    <div class="col-md-6">
                        <label>Start Date</label>

                        <input type="date"
                               name="WorkExperiences[@i].StartDate"
                               value="@Model.WorkExperiences[i].StartDate.ToString("yyyy-MM-dd")"
                               class="form-control" />
                    </div>

                    <div class="col-md-6">
                        <label>End Date</label>

                        <input type="date"
                               name="WorkExperiences[@i].EndDate"
                               value="@(Model.WorkExperiences[i].EndDate?.ToString("yyyy-MM-dd"))"
                               class="form-control end-date" />
                    </div>

                </div>

                <div class="form-check mb-2">

                    <input type="checkbox"
                           class="form-check-input current-work-checkbox"
                           name="WorkExperiences[@i].CurrentlyWorking"
                           value="true"
                    @(Model.WorkExperiences[i].CurrentlyWorking ? "checked" : "")
                           onchange="toggleEndDate(this)" />

                    <label class="form-check-label">
                        Currently Working Here
                    </label>

                </div>

                <textarea name="WorkExperiences[@i].Description"
                          class="form-control"
                          placeholder="Description">@Model.WorkExperiences[i].Description</textarea>

            </div>
        }

    </div>

    <button type="button"
            class="btn btn-secondary"
            onclick="addWorkExperience()">
        Add Work Experience
    </button>

    <hr />

    <h4>Projects</h4>

    <div id="projectsContainer">
        @for (int i = 0; i < Model.Projects.Count; i++)
        {
            <div class="card p-3 mb-3">

                <input name="Projects[@i].Name"
                       value="@Model.Projects[i].Name"
                       class="form-control mb-2"
                       placeholder="Project Name" />

                <textarea name="Projects[@i].Description"
                          class="form-control">@Model.Projects[i].Description</textarea>

            </div>
        }
    </div>

    <button type="button"
            class="btn btn-secondary"
            onclick="addProject()">
        Add Project
    </button>

    <hr />

    <div class="mt-3">
        <label>Motivation</label>

        <textarea asp-for="Motivation"
                  class="form-control"
                  rows="5"></textarea>
    </div>

    <hr />
    <h4>Extra-Curricular Activities</h4>

    <div id="activitiesContainer">
        @if (Model.ExtraCurricularActivities != null)
        {
            for (int i = 0; i < Model.ExtraCurricularActivities.Count; i++)
            {
                <div class="card mb-3 p-3 activity-item">
                    <div class="row mb-2">
                        <div class="col-md-5">
                            <label class="form-label">Activity Name</label>
                            <input asp-for="ExtraCurricularActivities[i].ActivityName"
                                   class="form-control" />
                        </div>

                        <div class="col-md-5">
                            <label class="form-label">Organization</label>
                            <input asp-for="ExtraCurricularActivities[i].Organization"
                                   class="form-control" />
                        </div>

                        <div class="col-md-2 d-flex align-items-end">
                            <button type="button"
                                    class="btn btn-danger remove-activity">
                                Remove
                            </button>
                        </div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-md-6">
                            <label class="form-label">Role</label>
                            <input asp-for="ExtraCurricularActivities[i].Role"
                                   class="form-control" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Period</label>
                            <input asp-for="ExtraCurricularActivities[i].Period"
                                   class="form-control" />
                        </div>
                    </div>

                    <div>
                        <label class="form-label">Description</label>
                        <textarea asp-for="ExtraCurricularActivities[i].Description"
                                  class="form-control"
                                  rows="3"></textarea>
                    </div>
                </div>
            }
        }
        <button type="button"
                class="btn btn-outline-primary mb-4"
                id="addActivityBtn">
            Add Activity
        </button>
    </div>

    <button type="submit" class="btn btn-primary mt-4">
        Save Profile
    </button>

</form>


<template id="activityTemplate">
    <div class="card mb-3 p-3 activity-item">
        <div class="row mb-2">
            <div class="col-md-5">
                <label class="form-label">Activity Name</label>
                <input name="ExtraCurricularActivities[INDEX].ActivityName"
                       class="form-control" />
            </div>

            <div class="col-md-5">
                <label class="form-label">Organization</label>
                <input name="ExtraCurricularActivities[INDEX].Organization"
                       class="form-control" />
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <button type="button"
                        class="btn btn-danger remove-activity">
                    Remove
                </button>
            </div>
        </div>

        <div class="row mb-2">
            <div class="col-md-6">
                <label class="form-label">Role</label>
                <input name="ExtraCurricularActivities[INDEX].Role"
                       class="form-control" />
            </div>

            <div class="col-md-6">
                <label class="form-label">Period</label>
                <input name="ExtraCurricularActivities[INDEX].Period"
                       class="form-control" />
            </div>
        </div>

        <div>
            <label class="form-label">Description</label>
            <textarea name="ExtraCurricularActivities[INDEX].Description"
                      class="form-control"
                      rows="3"></textarea>
        </div>
    </div>
</template>

@section Scripts
{
    <script src="~/js/profile.js"></script>
    <script>
        function addActivity(activity = null) {

        const container =
        document.getElementById("activitiesContainer");

        const index =
        container.querySelectorAll(".activity-item").length;

        const activityName =
        activity?.activityName ?? "";

        const organization =
        activity?.organization ?? "";

        const role =
        activity?.role ?? "";

        const period =
        activity?.period ?? "";

        const description =
        activity?.description ?? "";

        const html = `

        <div class="card mb-3 p-3 activity-item">

        <div class="row mb-2">

        <div class="col-md-5">

        <label class="form-label">
        Activity Name
        </label>

        <input name="ExtraCurricularActivities[${index}].ActivityName"
        class="form-control"
        value="${escapeHtml(activityName)}" />

        </div>

        <div class="col-md-5">

        <label class="form-label">
        Organization
        </label>

        <input name="ExtraCurricularActivities[${index}].Organization"
        class="form-control"
        value="${escapeHtml(organization)}" />

        </div>

        <div class="col-md-2 d-flex align-items-end">

        <button type="button"
        class="btn btn-danger w-100"
        onclick="removeItem(this)">
        Remove
        </button>

        </div>

        </div>

        <div class="row mb-2">

        <div class="col-md-6">

        <label class="form-label">
        Role
        </label>

        <input name="ExtraCurricularActivities[${index}].Role"
        class="form-control"
        value="${escapeHtml(role)}" />

        </div>

        <div class="col-md-6">

        <label class="form-label">
        Period
        </label>

        <input name="ExtraCurricularActivities[${index}].Period"
        class="form-control"
        value="${escapeHtml(period)}" />

        </div>

        </div>

        <div>

        <label class="form-label">
        Description
        </label>

        <textarea name="ExtraCurricularActivities[${index}].Description"
        class="form-control"
        rows="3">${escapeHtml(description)}</textarea>

        </div>

        </div>
        `;

        container.insertAdjacentHTML("beforeend", html);
        }

        document
        .getElementById("addActivityBtn")
        .addEventListener("click", () => addActivity());
    </script>
    <script>
        document.getElementById("uploadCvBtn").addEventListener("click", async () => {
            const file = document.getElementById("cvFileInput").files[0];
            const msgEl = document.getElementById("cvUploadMessage");
            if (!file) {
                msgEl.textContent = "Please select a file.";
                msgEl.className = "mt-3 text-danger";
                return;
            }
            msgEl.textContent = "Uploading...";
            msgEl.className = "mt-3 text-muted";
            try {
                const user = await uploadCv(file);
                populateProfileForm(user);
                msgEl.textContent = "CV uploaded. Form populated — review and save.";
                msgEl.className = "mt-3 text-success";
            } catch (err) {
                msgEl.textContent = err.message || "Upload failed.";
                msgEl.className = "mt-3 text-danger";
            }
        });
    </script>
    <script>
        function populateProfileForm(user) {

        setValue("FirstName", user.firstName);
        setValue("LastName", user.lastName);
        setValue("Age", user.age);
        setValue("Email", user.email);
        setValue("GitHub", user.gitHub);
        setValue("LinkedIn", user.linkedIn);
        setValue("Country", user.country);
        setValue("City", user.city);
        setValue("University", user.university);
        setValue("Address", user.address);
        setValue("Motivation", user.motivation);
        setValue("Phone", user.phone);

        const gender =
        document.getElementById("Gender");

        if (gender) {
        gender.value = user.gender;
        }

        const gradYear =
        document.getElementById("ExpectedGraduationYear");

        if (gradYear) {
        gradYear.value = user.expectedGraduationYear;
        }

        populateSkills(user.skills);
        populateWorkExperience(user.workExperiences);
        populateProjects(user.projects);
        populateActivities(user.extraCurricularActivities);
        }

        function setValue(id, value) {

        const element =
        document.getElementById(id);

        if (element && value !== null && value !== undefined) {

        element.value = value;
        }
        }
    </script>
    <script>
        function populateSkills(skills) {

        const container =
        document.getElementById("skills-container");

        if (!container) return;

        container.innerHTML = "";

        if (!skills) return;

        skills.forEach((skill, index) => {

        const name =
        skill.skill?.name || skill.name;

        if (!name) return;

        const html = `<div class="badge bg-primary p-2 me-2 mb-2 skill-item">
            ${escapeHtml(name)}
            <button type="button" class="btn-close btn-close-white ms-2" onclick="removeSkill(this)"></button>
            <input type="hidden" name="Skills[${index}].Skill.Name" value="${escapeHtml(name)}" />
        </div>`;

        container.insertAdjacentHTML("beforeend", html);
        });
        }
    </script>
    <script>
        function populateWorkExperience(items) {

        const container =
        document.getElementById("workExperienceContainer");

        container.innerHTML = "";

        if (!items) return;

        items.forEach(item => {

        addWorkExperience(item);
        });
        }
    </script>
    <script>
        function populateProjects(projects) {

        const container =
        document.getElementById("projectsContainer");

        container.innerHTML = "";

        if (!projects) return;

        projects.forEach(project => {

        addProject(project);
        });
        }
    </script>
    <script>
        function populateActivities(activities) {

        const container =
        document.getElementById("activitiesContainer");

        container.innerHTML = "";

        if (!activities) return;

        activities.forEach(activity => {

        addActivity(activity);
        });
        }
    </script>
    <script>
        function removeItem(button) {

        button.closest(".card").remove();

        reindexCollection("Projects", ".project-item");
        reindexCollection("WorkExperiences", ".work-item");
        reindexCollection("ExtraCurricularActivities", ".activity-item");
        }

        function reindexCollection(prefix, selector) {

        const items =
        document.querySelectorAll(selector);

        items.forEach((item, index) => {

        item.querySelectorAll("input, textarea, select")
        .forEach(field => {

        field.name = field.name.replace(
        new RegExp(`${prefix}\\[\\d+\\]`),
        `${prefix}[${index}]`
        );
        });
        });
        }

        function toggleEndDate(checkbox) {

        const card =
        checkbox.closest(".work-item");

        const endDate =
        card.querySelector(".end-date");

        endDate.disabled = checkbox.checked;

        if (checkbox.checked) {
        endDate.value = "";
        }
        }

        function formatDateForInput(dateString) {

        if (!dateString) {
        return "";
        }

        return dateString.split("T")[0];
        }

        function escapeHtml(value) {

        if (!value) {
        return "";
        }

        return value
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
        }
    </script>
}