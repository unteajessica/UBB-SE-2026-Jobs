@model PussyCats.Library.DTOs.UserPreferences
@{
    ViewData["Title"] = "Preferences";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Your Preferences</h2>
        <a asp-action="Edit" class="btn btn-primary">Edit</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Preferred roles</dt>
                <dd class="col-sm-9">
                    @if (Model.Roles is null || Model.Roles.Count == 0)
                    {
                        <span class="text-muted">None selected</span>
                    }
                    else
                    {
                        @foreach (var role in Model.Roles)
                        {
                            <span class="badge bg-secondary me-1">@role</span>
                        }
                    }
                </dd>

                <dt class="col-sm-3">Work mode</dt>
                <dd class="col-sm-9">@Model.WorkMode</dd>

                <dt class="col-sm-3">Location</dt>
                <dd class="col-sm-9">
                    @(string.IsNullOrWhiteSpace(Model.Location) ? "—" : Model.Location)
                </dd>
            </dl>
        </div>
    </div>
</div>
