@model PussyCats.Library.Domain.Document
@{
	ViewData["Title"] = "Document Details";
}

<section class="page-shell">
    <div class="detail-card">
        <div class="detail-card__header">
            <div>
                <p class="eyebrow">Document</p>
                <h2>@Model.DocumentName</h2>
            </div>
            <span class="pc-pill">@Model.UploadDate.ToString("dd MMM")</span>
        </div>
        <div class="detail-card__body">
            <div>
                <span class="detail-label">Document Id</span>
                <span class="detail-value">@Model.DocumentId</span>
            </div>
            <div>
                <span class="detail-label">File Path</span>
                <span class="detail-value">@Model.FilePath</span>
            </div>
            <div>
                <span class="detail-label">User</span>
                <span class="detail-value">@Model.User?.Name</span>
            </div>
            <div>
                <span class="detail-label">Upload Date</span>
                <span class="detail-value">@Model.UploadDate.ToString("g")</span>
            </div>
        </div>
        <div class="detail-card__actions">
            <a class="btn btn-dark" asp-action="Edit" asp-route-id="@Model.DocumentId">Edit</a>
            <a class="btn btn-outline-secondary" asp-action="Index">Back to list</a>
        </div>
    </div>
</section>
