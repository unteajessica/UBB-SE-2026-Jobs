<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="PussyCats_App.Views.Controls.SkillTestCardControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border Background="#3D2E4D" CornerRadius="12" Padding="18,14">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Image x:Name="BadgeIcon" Grid.Column="0"
                   Width="55" Height="55" VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1" Margin="16,0" Spacing="4" VerticalAlignment="Center">
                <TextBlock x:Name="TestNameText"
                           Foreground="White" FontSize="14" FontWeight="Medium"/>
                <TextBlock x:Name="ScoreText"
                           Foreground="#BDA4CC" FontSize="12"/>
                <TextBlock x:Name="DateText"
                           Foreground="#BDA4CC" FontSize="12"/>
            </StackPanel>

            <Button x:Name="RetakeButton" Grid.Column="2"
                    Content="RETAKE"
                    Background="#9A74B3" Foreground="White"
                    BorderThickness="0" CornerRadius="6"
                    VerticalAlignment="Center"
                    Click="RetakeButton_Click"/>
        </Grid>
    </Border>
</UserControl>
