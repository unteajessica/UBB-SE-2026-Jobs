<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PussyCats_App.Views.Company.CompanyRecommendationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="4" Padding="0,28,0,20">
            <TextBlock Text="Applicant Review" FontSize="20" FontWeight="SemiBold"/>
            <TextBlock Text="Review applicants for your company's job postings."
                       FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <!-- Card view -->
        <Grid x:Name="CardViewPanel" Grid.Row="1" Visibility="Collapsed">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel MaxWidth="600" MinWidth="380" HorizontalAlignment="Center" Padding="16,0,16,24">
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            x:Name="ApplicantCardBorder"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="12" Padding="28,24"
                            Tapped="OnExpandClick">
                        <Border.RenderTransform>
                            <TranslateTransform/>
                        </Border.RenderTransform>
                        <StackPanel Spacing="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="48" Height="48" CornerRadius="24"
                                        Background="#FF374151" Margin="0,0,16,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="AvatarInitial" HorizontalAlignment="Center"
                                               VerticalAlignment="Center" Foreground="White"
                                               FontWeight="SemiBold" FontSize="18"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock x:Name="ApplicantNameText" FontSize="18" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="JobTitleText" FontSize="13" TextTrimming="CharacterEllipsis"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                                <Border Grid.Column="2" CornerRadius="8" Padding="12,6"
                                        Background="#FF10B981" VerticalAlignment="Center" Margin="12,0,0,0">
                                    <TextBlock x:Name="MatchScoreText" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                </Border>
                            </Grid>
                            <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,18,0,18"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                                    <TextBlock Text="Location" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="LocationText" FontSize="13" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4" Margin="8,0">
                                    <TextBlock Text="Experience" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="ExperienceText" FontSize="13" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="4" Margin="8,0,0,0">
                                    <TextBlock Text="Education" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="EducationText" FontSize="13" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Grid>
                            <StackPanel Spacing="8" Margin="0,18,0,0">
                                <TextBlock Text="TOP SKILLS" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <ItemsControl x:Name="TopSkillsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,6" Height="24">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="36"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="12" VerticalAlignment="Center"/>
                                                <ProgressBar Grid.Column="1" Value="{Binding Score}" Maximum="100"
                                                             Height="6" Margin="8,0" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Score}" FontSize="12"
                                                           FontWeight="SemiBold" VerticalAlignment="Center" TextAlignment="Right"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock x:Name="MoreSkillsText" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" Visibility="Collapsed"/>
                            </StackPanel>
                            <Button Content="View Details" Click="OnExpandClick"
                                    HorizontalAlignment="Stretch" Margin="0,18,0,0" Padding="18,10" CornerRadius="6"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Expanded view -->
        <Grid x:Name="ExpandedViewPanel" Grid.Row="1" Visibility="Collapsed">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel MaxWidth="700" MinWidth="380" HorizontalAlignment="Center"
                            Spacing="16" Padding="16,0,16,32">
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Click="OnCollapseClick" Padding="10,6" CornerRadius="6" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE72B;" FontSize="14"/>
                                <TextBlock Text="Back" FontSize="14"/>
                            </StackPanel>
                        </Button>
                        <Border Grid.Column="2" CornerRadius="8" Padding="14,8"
                                Background="#FF10B981" VerticalAlignment="Center">
                            <TextBlock x:Name="ExpandedMatchScoreText" FontSize="16" FontWeight="Bold" Foreground="White"/>
                        </Border>
                    </Grid>

                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="12" Padding="28,20">
                        <StackPanel Spacing="4">
                            <TextBlock x:Name="ExpandedNameText" FontSize="22" FontWeight="Bold"/>
                            <TextBlock x:Name="ExpandedJobText" FontSize="14"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="12" Padding="28,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                                <TextBlock Text="Location" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="ExpandedLocationText" FontSize="14" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4" Margin="8,0">
                                <TextBlock Text="Years of Experience" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="ExpandedExperienceText" FontSize="14" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4" Margin="8,0,0,0">
                                <TextBlock Text="Education" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="ExpandedEducationText" FontSize="14" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="12" Padding="28,20">
                        <StackPanel Spacing="8">
                            <TextBlock Text="RESUME" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="ResumeText" FontSize="13" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="12" Padding="28,20">
                        <StackPanel Spacing="8">
                            <TextBlock Text="JOB DESCRIPTION" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="JobDescriptionText" FontSize="13" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="12" Padding="28,20">
                        <StackPanel Spacing="8">
                            <TextBlock Text="ALL SKILLS" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <ItemsControl x:Name="AllSkillsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,6" Height="26">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="40"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="13" VerticalAlignment="Center"/>
                                            <ProgressBar Grid.Column="1" Value="{Binding Score}" Maximum="100"
                                                         Height="8" Margin="8,0" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Score}" FontSize="13"
                                                       FontWeight="SemiBold" VerticalAlignment="Center" TextAlignment="Right"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="12" Padding="28,20">
                        <StackPanel Spacing="12">
                            <TextBlock Text="COMPATIBILITY BREAKDOWN" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <Grid ColumnSpacing="16" RowSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Skill Match" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="BreakdownSkillText" FontSize="16" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2">
                                    <TextBlock Text="Keyword Match" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="BreakdownKeywordText" FontSize="16" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Preference Match" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="BreakdownPreferenceText" FontSize="16" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2">
                                    <TextBlock Text="Promotion Score" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="BreakdownPromotionText" FontSize="16" FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="12" Padding="28,20">
                        <StackPanel Spacing="8">
                            <TextBlock Text="CONTACT" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="Email" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="ContactEmailText" FontSize="13"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="Phone" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="ContactPhoneText" FontSize="13"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Skip" Click="OnSkipClick"
                                HorizontalAlignment="Stretch" Height="44" CornerRadius="8"
                                Background="#FFEF4444" Foreground="White"/>
                        <Button Grid.Column="1" Content="Accept" Click="OnAdvanceClick"
                                HorizontalAlignment="Stretch" Height="44" CornerRadius="8"
                                Background="#FF10B981" Foreground="White"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Empty state -->
        <Grid x:Name="EmptyStatePanel" Grid.Row="1" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                <FontIcon Glyph="&#xE779;" FontSize="48"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                          HorizontalAlignment="Center"/>
                <TextBlock Text="No more applicants to review" FontSize="20" FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Check back later for new applications." FontSize="14"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center"/>
                <Button Content="Refresh" Click="OnRefreshClick"
                        HorizontalAlignment="Center" Margin="0,8,0,0" Padding="24,10" CornerRadius="6"/>
            </StackPanel>
        </Grid>

        <!-- Loading -->
        <Grid x:Name="LoadingPanel" Grid.Row="1" Visibility="Collapsed">
            <ProgressRing IsActive="True" Width="48" Height="48"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>

        <!-- Action buttons -->
        <StackPanel x:Name="ActionButtonsPanel" Grid.Row="2"
                    Orientation="Horizontal" HorizontalAlignment="Center"
                    Spacing="20" Padding="0,16,0,24">
            <Button x:Name="SkipButton" Click="OnSkipClick"
                    Width="64" Height="64" CornerRadius="32" Padding="0"
                    Background="#FFEF4444" ToolTipService.ToolTip="Skip applicant">
                <FontIcon Glyph="&#xE711;" FontSize="24" Foreground="White"/>
            </Button>
            <Button x:Name="UndoButton" Click="OnUndoClick"
                    Width="48" Height="48" CornerRadius="24" Padding="0"
                    VerticalAlignment="Center" ToolTipService.ToolTip="Undo last action">
                <FontIcon Glyph="&#xE7A7;" FontSize="16"/>
            </Button>
            <Button x:Name="AdvanceButton" Click="OnAdvanceClick"
                    Width="64" Height="64" CornerRadius="32" Padding="0"
                    Background="#FF10B981" ToolTipService.ToolTip="Advance applicant">
                <FontIcon Glyph="&#xE8FB;" FontSize="24" Foreground="White"/>
            </Button>
        </StackPanel>
    </Grid>
</Page>
