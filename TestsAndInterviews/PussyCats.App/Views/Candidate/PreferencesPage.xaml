<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PussyCats_App.Views.Candidate.PreferencesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel Spacing="24" Padding="40" MaxWidth="600" HorizontalAlignment="Left">

            <StackPanel Spacing="8">
                <TextBlock Text="Job Preferences" FontSize="32" FontWeight="SemiBold"/>
                <TextBlock Text="Set up your filters so we can match you with the perfect jobs." Foreground="Gray"/>
            </StackPanel>

            <StackPanel Spacing="8">
                <TextBlock Text="Preferred Job Roles (Max 3)" FontWeight="Medium"/>
                <ListView x:Name="RolesListView"
                          SelectionMode="Multiple"
                          SelectionChanged="RolesListView_SelectionChanged"
                          Height="280" CornerRadius="8"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                          BorderThickness="1"
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
                <TextBlock x:Name="RoleWarningText"
                           Foreground="Red" Visibility="Collapsed"
                           Text="You can only select a maximum of 3 roles."/>
            </StackPanel>

            <ComboBox x:Name="WorkModeComboBox"
                      Header="Preferred Work Mode" Width="300"
                      PlaceholderText="Select work mode">
                <ComboBoxItem Content="Remote"  Tag="Remote"/>
                <ComboBoxItem Content="Hybrid"  Tag="Hybrid"/>
                <ComboBoxItem Content="On-site" Tag="OnSite"/>
            </ComboBox>

            <AutoSuggestBox x:Name="LocationAutoSuggestBox"
                            Header="Location (City, Country)"
                            PlaceholderText="e.g., Bucharest, Romania"
                            HorizontalAlignment="Stretch"
                            TextChanged="LocationAutoSuggestBox_TextChanged"
                            SuggestionChosen="LocationAutoSuggestBox_SuggestionChosen"/>

            <Button Content="Save Preferences"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="SaveButton_Click" Width="150" Margin="0,16,0,0"/>

            <TextBlock x:Name="SuccessMessage"
                       Foreground="Green" FontWeight="SemiBold"
                       Visibility="Collapsed"/>
        </StackPanel>
    </ScrollViewer>
</Page>
