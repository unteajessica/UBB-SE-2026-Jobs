<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PussyCats_App.Views.Candidate.UserStatusPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:PussyCats_App.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F0F2F5">

    <Page.Resources>
        <converters:BoolToVisibilityConverter  x:Key="BoolToVisibility"/>
        <converters:MatchStatusToColorConverter x:Key="StatusToColor"/>
        <converters:MatchStatusToTextConverter  x:Key="StatusToText"/>

        <DataTemplate x:Key="JobCardTemplate">
            <Border Background="White" CornerRadius="10" Padding="24,28"
                    BorderBrush="#E1E1E1" BorderThickness="1" Margin="0,0,0,0">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="{Binding TruncatedDescription}"
                                   FontWeight="Bold" FontSize="15" TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" Foreground="Black"/>
                        <Border Grid.Column="1"
                                Background="{Binding Status, Converter={StaticResource StatusToColor}}"
                                CornerRadius="10" Padding="9,3" VerticalAlignment="Center" Margin="10,0,0,0">
                            <TextBlock Text="{Binding Status, Converter={StaticResource StatusToText}}"
                                       Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                        </Border>
                    </Grid>
                    <TextBlock Text="{Binding CompanyName}" FontSize="13" FontWeight="SemiBold" Foreground="#505050"/>
                    <TextBlock Text="{Binding FormattedDate}" FontSize="12" Foreground="#A0A0A0"/>
                    <TextBlock Text="{Binding FormattedScore}" FontSize="12" FontWeight="SemiBold" Foreground="#1565C0" Margin="0,2,0,0"/>
                    <TextBlock Text="{Binding FeedbackMessage}" FontSize="12" Foreground="#757575"
                               TextWrapping="Wrap" FontStyle="Italic" Margin="0,2,0,0"
                               Visibility="{Binding HasFeedback, Converter={StaticResource BoolToVisibility}}"/>
                    <Button Content="View Job Details" Tag="{Binding}"
                            FontSize="12" Padding="12,6" CornerRadius="6"
                            Click="ViewJobDetails_Click" Foreground="Black" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="UnderscoredSkillTemplate">
            <Grid Margin="0,0,0,2" ColumnDefinitions="80,*,30">
                <TextBlock Grid.Column="0" Text="{Binding SkillName}" FontSize="12"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Foreground="Black"/>
                <ProgressBar Grid.Column="1" Value="{Binding UserScore}" Maximum="100"
                             Foreground="Black" VerticalAlignment="Center" Margin="4,0"/>
                <TextBlock Grid.Column="2" Text="{Binding UserScore}" FontSize="12"
                           VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="Black"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="MissingSkillSidebarTemplate">
            <TextBlock Text="{Binding SkillName}" FontSize="12" Foreground="#D32F2F" TextWrapping="Wrap"/>
        </DataTemplate>
    </Page.Resources>

    <Grid ColumnDefinitions="*,290" Padding="28,20,16,20">
        <Grid Grid.Column="0" Padding="0,0,16,0" RowDefinitions="Auto,Auto,*">
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="My Application Status" FontSize="22" FontWeight="Bold"
                           VerticalAlignment="Center" Foreground="Black"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Spacing="8">
                    <Button x:Name="RefreshButton" Content="Refresh"
                            Click="RefreshButton_Click" Foreground="Black" Padding="12,6" Height="36"/>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,16">
                <Button x:Name="FilterAll"      Content="All"      Tag="All"      Click="Filter_Click"/>
                <Button x:Name="FilterApplied"  Content="Applied"  Tag="Applied"  Click="Filter_Click"/>
                <Button x:Name="FilterAccepted" Content="Accepted" Tag="Accepted" Click="Filter_Click"/>
                <Button x:Name="FilterRejected" Content="Rejected" Tag="Rejected" Click="Filter_Click"/>
            </StackPanel>

            <Grid Grid.Row="2">
                <ProgressRing x:Name="LoadingRing" IsActive="True" Width="48" Height="48"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
                <TextBlock Text="Unable to load your applications. Please try again."
                           Foreground="Red" TextAlignment="Center" FontSize="14"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"/>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8"
                            Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding EmptyMessage}" FontSize="14"
                               TextAlignment="Center" TextWrapping="Wrap" MaxWidth="360" Foreground="Black"/>
                    <Button x:Name="GoToRecommendationsButton" Content="Go to Recommendations"
                            Click="GoToRecommendationsButton_Click"
                            HorizontalAlignment="Center" Margin="0,8,0,0"
                            Visibility="{Binding ShowGoToRecommendations, Converter={StaticResource BoolToVisibility}}"/>
                </StackPanel>
                <ScrollViewer Visibility="{Binding ShowCards, Converter={StaticResource BoolToVisibility}}">
                    <ItemsRepeater ItemsSource="{Binding FilteredJobs}"
                                   ItemTemplate="{StaticResource JobCardTemplate}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MaximumRowsOrColumns="2"
                                               MinColumnSpacing="16" MinRowSpacing="16"
                                               ItemsStretch="Fill"/>
                        </ItemsRepeater.Layout>
                    </ItemsRepeater>
                </ScrollViewer>
            </Grid>
        </Grid>

        <Border Grid.Column="1" Background="White" CornerRadius="8"
                Padding="16" VerticalAlignment="Top"
                BorderBrush="Black" BorderThickness="0,3,0,0">
            <StackPanel Spacing="10">
                <TextBlock Text="Skill Gap Analysis" FontWeight="Bold" FontSize="15" Foreground="Black"/>
                <TextBlock Text="{Binding SkillGapMessage}" Foreground="Black" FontSize="12"
                           TextWrapping="Wrap"
                           Visibility="{Binding HasSkillGapMessage, Converter={StaticResource BoolToVisibility}}"/>
                <StackPanel Spacing="8"
                            Visibility="{Binding ShowSkillData, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding SkillGapSummaryText}" FontSize="12" Foreground="Black" Margin="0,0,0,4"/>
                    <StackPanel Spacing="4"
                                Visibility="{Binding HasUnderscoredSkills, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="Skills to Improve:" FontWeight="SemiBold" FontSize="12" Foreground="Black"/>
                        <ItemsControl ItemsSource="{Binding UnderscoredSkills}"
                                      ItemTemplate="{StaticResource UnderscoredSkillTemplate}"/>
                    </StackPanel>
                    <StackPanel Spacing="4" Margin="0,8,0,0"
                                Visibility="{Binding HasSidebarMissingSkills, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="Missing Skills:" FontWeight="SemiBold" FontSize="12" Foreground="Black"/>
                        <ItemsControl ItemsSource="{Binding SkillGapMissingSkills}"
                                      ItemTemplate="{StaticResource MissingSkillSidebarTemplate}"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
