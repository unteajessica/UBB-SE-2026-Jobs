<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PussyCats_App.Views.Candidate.DocumentsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel Padding="30,30,30,40" Spacing="30">

            <Border Background="#9b72a8" CornerRadius="12" Padding="24">
                <StackPanel Spacing="16">
                    <TextBlock Text="Upload Document" Foreground="White" FontSize="18" FontWeight="Bold"/>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Document Name" Foreground="White" FontSize="14"/>
                        <TextBox x:Name="txtDocumentName"
                                 PlaceholderText="e.g. AWS Certificate 2024"
                                 TextChanged="OnDocumentNameChanged"
                                 MaxWidth="400" HorizontalAlignment="Left"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button x:Name="btnBrowse" Content="Browse File..." Click="OnBrowseClick"/>
                        <TextBlock x:Name="selectedFileLabel" Text="No file selected"
                                   Foreground="White" VerticalAlignment="Center" FontSize="13" Opacity="0.85"/>
                    </StackPanel>
                    <TextBlock Text="Accepted formats: PDF, JPG, PNG" Foreground="White" FontSize="12" Opacity="0.7"/>
                    <TextBlock x:Name="uploadErrorLabel" Foreground="#FFD0D0" FontSize="13"
                               TextWrapping="Wrap" Visibility="Collapsed"/>
                    <Button x:Name="btnUpload" Content="Upload" Click="OnUploadClick" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <StackPanel Spacing="12">
                <TextBlock Text="Uploaded Documents" FontSize="18" FontWeight="Bold"/>
                <TextBlock x:Name="noDocumentsLabel" Text="No documents uploaded yet."
                           Foreground="Gray" FontSize="14" Visibility="Collapsed"/>
                <TextBlock x:Name="statusLabel" Foreground="#c0392b" FontSize="13"
                           TextWrapping="Wrap" Visibility="Collapsed"/>
                <ListView x:Name="listViewDocuments" SelectionMode="Single" IsItemClickEnabled="False">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#f5f0fa" CornerRadius="8" Padding="16,12" Margin="0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DocumentName}" FontSize="15" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding UploadDate}" FontSize="12" Foreground="Gray"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Edit"   Margin="0,0,10,0"
                                            Tag="{Binding}" Click="OnEditClick"/>
                                    <Button Grid.Column="2" Content="Delete"
                                            Tag="{Binding}" Click="OnDeleteClick"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
