<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PussyCats_App.Views.Candidate.SkillGapPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:PussyCats_App.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F0F2F5">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>

        <DataTemplate x:Key="UnderscoredSkillTemplate">
            <Border Background="White" CornerRadius="8" Padding="18"
                    BorderBrush="#E6E6E6" BorderThickness="1" Margin="0,0,0,0">
                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="{Binding SkillName}"
                                   FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="Black"/>
                        <Border Grid.Column="1" Background="#FFF3E0" CornerRadius="6"
                                Padding="8,3" VerticalAlignment="Center" Margin="10,0,0,0">
                            <TextBlock Text="{Binding GapText}" FontSize="11" FontWeight="SemiBold" Foreground="#E65100"/>
                        </Border>
                    </Grid>
                    <ProgressBar Value="{Binding UserScore}" Maximum="100" Foreground="#0097A7" Height="8"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="{Binding UserScoreText}"       FontSize="12" Foreground="#787878"/>
                        <TextBlock Grid.Column="1" Text="{Binding AverageRequiredScoreText}" FontSize="12" Foreground="#787878"/>
                    </Grid>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="MissingSkillTemplate">
            <Border Background="White" CornerRadius="8" BorderBrush="#E6E6E6" BorderThickness="1" Margin="0,0,0,0">
                <Grid ColumnDefinitions="5,*">
                    <Border Grid.Column="0" Background="#D32F2F" CornerRadius="7,0,0,7"/>
                    <StackPanel Grid.Column="1" Spacing="4" Padding="16,14">
                        <TextBlock Text="{Binding SkillName}" FontSize="14" FontWeight="SemiBold" Foreground="Black"/>
                        <TextBlock Text="{Binding JobCountText}" FontSize="12" Foreground="#969696" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid Padding="40,28">
        <Grid RowDefinitions="Auto,*">
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Content="← Back to My Status" VerticalAlignment="Center"
                        Click="BackToStatus_Click" Foreground="Black" Padding="12,6" Height="36"/>
                <TextBlock Grid.Column="1" Text="Skill Gap Analysis" FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Black"/>
                <Button Grid.Column="2" Content="Refresh" VerticalAlignment="Center"
                        Click="RefreshButton_Click" Foreground="Black" Padding="12,6" Height="36"/>
            </Grid>

            <ProgressRing Grid.Row="1" IsActive="True" Width="48" Height="48"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>

            <ScrollViewer Grid.Row="1"
                          Visibility="{Binding ShowContent, Converter={StaticResource BoolToVisibility}}">
                <StackPanel Spacing="24" MaxWidth="720" Padding="0,0,0,20">
                    <Border Background="White" CornerRadius="10" Padding="28"
                            Visibility="{Binding HasSummaryMessage, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding SummaryMessage}" FontSize="14"
                                   HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Foreground="Black"/>
                    </Border>

                    <StackPanel Spacing="24"
                                Visibility="{Binding HasSkillData, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <Border Background="#FFEBEB" CornerRadius="10" Padding="24,18" MinWidth="160"
                                    BorderBrush="#D32F2F" BorderThickness="0,0,0,3">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding MissingCount}" FontSize="40" FontWeight="Bold" Foreground="#D32F2F"/>
                                    <TextBlock Text="Missing Skills" FontSize="13" Foreground="#505050"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#FFF3F0" CornerRadius="10" Padding="24,18" MinWidth="160"
                                    BorderBrush="#E65100" BorderThickness="0,0,0,3">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding ImproveCount}" FontSize="40" FontWeight="Bold" Foreground="#E65100"/>
                                    <TextBlock Text="Skills to Improve" FontSize="13" Foreground="#505050"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Spacing="12"
                                    Visibility="{Binding HasSkillsToImprove, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="Skills to Improve" FontSize="17" FontWeight="Bold" Foreground="Black"/>
                            <ItemsControl ItemsSource="{Binding SkillsToImprove}"
                                          ItemTemplate="{StaticResource UnderscoredSkillTemplate}">
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Margin" Value="0,0,0,10"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Spacing="12"
                                    Visibility="{Binding HasMissingSkills, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="Missing Skills" FontSize="17" FontWeight="Bold" Foreground="Black"/>
                            <ItemsControl ItemsSource="{Binding MissingSkills}"
                                          ItemTemplate="{StaticResource MissingSkillTemplate}">
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Margin" Value="0,0,0,10"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
