<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PussyCats_App.Views.Candidate.MatchHistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Match History" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,16"/>
            <ListView x:Name="MatchesListView" Grid.Row="1" SelectionMode="Single"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                      BorderThickness="1" CornerRadius="8"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <ListView.HeaderTemplate>
                    <DataTemplate>
                        <Grid Padding="16,12" Background="{ThemeResource LayerFillColorAltBrush}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Company Name" FontWeight="SemiBold" Grid.Column="0"/>
                            <TextBlock Text="Job Role"     FontWeight="SemiBold" Grid.Column="1"/>
                            <TextBlock Text="Match Date"   FontWeight="SemiBold" Grid.Column="2"/>
                        </Grid>
                    </DataTemplate>
                </ListView.HeaderTemplate>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="16,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding CompanyName}" Grid.Column="0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding JobRole}"     Grid.Column="1" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding MatchDate}"   Grid.Column="2" VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <Grid Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
              Padding="24" CornerRadius="8" BorderThickness="1"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Activity Overview" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock x:Name="totalMatchesLabel"       Text="Total Matches: 0" FontSize="15"/>
                <TextBlock x:Name="matchesLastMonthLabel"   Text="Last Month: 0" FontSize="15"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock x:Name="matchesLastSixMonthsLabel" Text="Last 6 Months: 0" FontSize="15"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock x:Name="matchesLastYearLabel"    Text="Last Year: 0" FontSize="15"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Matches per Position" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>
                <ListView x:Name="PositionStatsListView" SelectionMode="None"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                          BorderThickness="1" CornerRadius="8" MaxHeight="200"
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <ListView.HeaderTemplate>
                        <DataTemplate>
                            <Grid Padding="16,8" Background="{ThemeResource LayerFillColorAltBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Job Role"    FontWeight="SemiBold" Grid.Column="0"/>
                                <TextBlock Text="Match Count" FontWeight="SemiBold" Grid.Column="1"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.HeaderTemplate>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="16,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding JobRole}" Grid.Column="0"/>
                                <TextBlock Text="{Binding Count}"   Grid.Column="1"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
