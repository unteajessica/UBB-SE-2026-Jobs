<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PussyCats_App.Views.Candidate.PublicProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="40">
        <TextBlock x:Name="ProfileUnavailableTextBlock"
                   Text="Profile unavailable"
                   FontSize="32" FontWeight="Bold"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="Collapsed"/>

        <ScrollViewer x:Name="ProfileContentPanel" VerticalScrollBarVisibility="Auto">
            <Grid ColumnSpacing="40">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="20">
                    <Border CornerRadius="100" Width="200" Height="200"
                            HorizontalAlignment="Center"
                            BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                            BorderThickness="2">
                        <Image x:Name="ProfilePhoto" Stretch="UniformToFill"/>
                    </Border>
                    <TextBlock x:Name="LevelLabel" Text="Level --"
                               FontSize="24" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="25">
                    <TextBlock Text="User Details" FontSize="22" FontWeight="SemiBold"/>
                    <Grid ColumnSpacing="20" RowSpacing="15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="First Name" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" FontSize="12"/>
                            <TextBlock x:Name="FirstNameLabel" FontSize="16"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1">
                            <TextBlock Text="Last Name" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" FontSize="12"/>
                            <TextBlock x:Name="LastNameLabel" FontSize="16"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0">
                            <TextBlock Text="Email" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" FontSize="12"/>
                            <TextBlock x:Name="EmailLabel" FontSize="16"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1">
                            <TextBlock Text="Phone" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" FontSize="12"/>
                            <TextBlock x:Name="PhoneLabel" FontSize="16"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="0">
                            <TextBlock Text="Gender" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" FontSize="12"/>
                            <TextBlock x:Name="GenderLabel" FontSize="16"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="1">
                            <TextBlock Text="Country" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" FontSize="12"/>
                            <TextBlock x:Name="CountryLabel" FontSize="16"/>
                        </StackPanel>
                        <StackPanel Grid.Row="3" Grid.Column="0">
                            <TextBlock Text="University" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" FontSize="12"/>
                            <TextBlock x:Name="UniversityLabel" FontSize="16"/>
                        </StackPanel>
                        <StackPanel Grid.Row="3" Grid.Column="1">
                            <TextBlock Text="Graduation Year" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" FontSize="12"/>
                            <TextBlock x:Name="GradYearLabel" FontSize="16"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="20">
                        <HyperlinkButton x:Name="GithubLink"  Content="GitHub"/>
                        <HyperlinkButton x:Name="LinkedinLink" Content="LinkedIn"/>
                    </StackPanel>
                    <TextBlock Text="Skill Test Results" FontSize="20" FontWeight="SemiBold" Margin="0,20,0,0"/>
                    <StackPanel x:Name="SkillTestsContainer" Spacing="8"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
