<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PussyCats_App.Views.TI.TiInterviewSlotsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dtos="using:PussyCats.App.Dtos.TI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Available Interview Slots" FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="Browse and book an interview slot with a recruiter."
                       FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Status message -->
        <TextBlock Grid.Row="1" Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                   Foreground="#22c55e" FontSize="14" Margin="0,0,0,12"
                   Visibility="{x:Bind ViewModel.StatusMessage, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}"/>

        <!-- Date filter -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12" Margin="0,0,0,16">
            <CalendarDatePicker Header="Date" Date="{x:Bind ViewModel.SelectedDate, Mode=TwoWay}" Width="220"/>
            <Button Content="Filter" Click="Filter_Click" VerticalAlignment="Bottom"
                    Background="#8494FF" Foreground="White" Padding="16,8" CornerRadius="8"/>
        </StackPanel>

        <!-- Slots grid -->
        <Grid Grid.Row="3">
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Width="48" Height="48" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.AvailableSlots, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout MinItemWidth="280" MinColumnSpacing="16" MinRowSpacing="16"/>
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="dtos:TiSlotDto">
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="12" Padding="20">
                                <StackPanel Spacing="12">
                                    <Border Background="#8494FF" CornerRadius="20" Padding="12,6" HorizontalAlignment="Left">
                                        <TextBlock Text="{x:Bind InterviewType}" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                    </Border>
                                    <TextBlock Text="{x:Bind TimeRange}" FontSize="18" FontWeight="SemiBold"/>
                                    <StackPanel Spacing="4">
                                        <TextBlock FontSize="13">
                                            <Run Text="Duration: "/>
                                            <Run Text="{x:Bind Duration}"/>
                                            <Run Text=" min"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <Button Content="Book This Slot" Tag="{x:Bind}" Click="BookSlot_Click"
                                            Background="#8494FF" Foreground="White"
                                            HorizontalAlignment="Stretch" CornerRadius="8" Padding="0,10"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
