<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PussyCats_App.Views.TI.TiLeaderboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="← Back to Tests" Click="Back_Click" Margin="0,0,16,0"
                    Background="Transparent" BorderThickness="0"/>
            <TextBlock Grid.Column="1" Text="Leaderboard" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
        </Grid>

        <!-- User rank alert -->
        <Border Grid.Row="1" Background="#EFF6FF" CornerRadius="8" Padding="16,12" Margin="0,0,0,16"
                Visibility="{x:Bind ViewModel.CurrentUserEntry, Mode=OneWay, Converter={StaticResource ObjectToVisibilityConverter}}">
            <TextBlock FontSize="14">
                <Run Text="Your ranking: "/>
                <Run Text="#" FontWeight="Bold"/>
                <Run Text="{x:Bind ViewModel.CurrentUserEntry.RankPosition, Mode=OneWay}" FontWeight="Bold"/>
                <Run Text=" with score "/>
                <Run Text="{x:Bind ViewModel.CurrentUserEntry.NormalizedScore, Mode=OneWay}" FontWeight="Bold"/>
            </TextBlock>
        </Border>

        <!-- Top 3 -->
        <ItemsRepeater Grid.Row="2" ItemsSource="{x:Bind ViewModel.TopEntries, Mode=OneWay}" Margin="0,0,0,16">
            <ItemsRepeater.Layout>
                <UniformGridLayout MinItemWidth="200" MinColumnSpacing="16"/>
            </ItemsRepeater.Layout>
            <ItemsRepeater.ItemTemplate>
                <DataTemplate>
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="12" Padding="20">
                        <StackPanel Spacing="8">
                            <TextBlock FontSize="22" FontWeight="Bold">
                                <Run Text="#"/>
                                <Run Text="{Binding RankPosition}"/>
                            </TextBlock>
                            <TextBlock FontSize="13">
                                <Run Text="User: "/>
                                <Run Text="{Binding UserId}"/>
                            </TextBlock>
                            <TextBlock FontSize="16" FontWeight="SemiBold">
                                <Run Text="Score: "/>
                                <Run Text="{Binding NormalizedScore}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsRepeater.ItemTemplate>
        </ItemsRepeater>

        <!-- Full ranking table -->
        <Border Grid.Row="3" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Table header -->
                <Grid Grid.Row="0" Padding="20,14" Background="{ThemeResource LayerFillColorDefaultBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="160"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Rank" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" Text="User ID" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="2" Text="Score" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="3" Text="Tie Break" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="4" Text="Last Updated" FontWeight="SemiBold"/>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.PageEntries, Mode=OneWay}">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="20,12" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="160"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding RankPosition}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding UserId}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding NormalizedScore}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{Binding TieBreakPriority}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="{Binding LastRecalculationAt}" FontSize="12"
                                               VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Pagination -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16" Margin="0,16,0,0">
            <Button Content="← Prev" Click="PrevPage_Click"
                    IsEnabled="{x:Bind ViewModel.CanGoPrev, Mode=OneWay}" Padding="14,8"/>
            <TextBlock Text="{x:Bind ViewModel.PageInfo, Mode=OneWay}"
                       VerticalAlignment="Center" FontSize="14"/>
            <Button Content="Next →" Click="NextPage_Click"
                    IsEnabled="{x:Bind ViewModel.CanGoNext, Mode=OneWay}" Padding="14,8"/>
        </StackPanel>
    </Grid>
</Page>
