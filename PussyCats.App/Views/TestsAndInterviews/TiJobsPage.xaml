<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PussyCats_App.Views.TestsAndInterviews.TiJobsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dtos="using:PussyCats.App.Dtos.TI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Job Postings" FontSize="24" FontWeight="Bold"/>
                <TextBlock Text="Browse all available job postings" FontSize="13"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="+ Post a Job" Click="CreateJob_Click"
                    Background="#8494FF" Foreground="White" Padding="14,8" CornerRadius="8"
                    x:Name="PostJobButton" Visibility="Collapsed"/>
        </Grid>

        <!-- Job list -->
        <Grid Grid.Row="1">
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Width="48" Height="48" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.Jobs, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout MinItemWidth="320" MinColumnSpacing="16" MinRowSpacing="16"/>
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="dtos:TiJobPostingDto">
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="12" Padding="20">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="{x:Bind JobTitle}" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                    <TextBlock Text="{x:Bind IndustryField}" FontSize="13"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <StackPanel Spacing="4">
                                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                            <Run Text="Type: "/>
                                            <Run Text="{x:Bind JobType}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                            <Run Text="Level: "/>
                                            <Run Text="{x:Bind ExperienceLevel}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                            <Run Text="Location: "/>
                                            <Run Text="{x:Bind JobLocation}"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock Text="{x:Bind JobDescription}" FontSize="13" TextWrapping="Wrap"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               MaxLines="2" TextTrimming="CharacterEllipsis"/>
                                    <!-- Company actions (hidden by default, shown when in Company mode) -->
                                    <StackPanel Orientation="Horizontal" Spacing="8" Visibility="Collapsed">
                                        <Button Content="Applicants" Tag="{x:Bind}" Click="ViewApplicants_Click"
                                                Background="Transparent" Padding="10,6"/>
                                        <Button Content="Pay" Tag="{x:Bind}" Click="Pay_Click"
                                                Background="#22c55e" Foreground="White" Padding="10,6" CornerRadius="6"/>
                                        <Button Content="Delete" Tag="{x:Bind}" Click="DeleteJob_Click"
                                                Background="#FFef4444" Foreground="White" Padding="10,6" CornerRadius="6"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
