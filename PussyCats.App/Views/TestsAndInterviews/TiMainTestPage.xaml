<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PussyCats_App.Views.TestsAndInterviews.TiMainTestPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:PussyCats.App.ViewModels.TI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F0EEFF">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="1" Background="White" Padding="32,20" BorderBrush="#E8E4FF" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#8494FF" CornerRadius="12" Width="48" Height="48" Margin="0,0,16,0">
                    <TextBlock Text="&lt;/&gt;" Foreground="White" FontSize="18" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Computer Science Tests" FontSize="22" FontWeight="Bold" Foreground="#1a1a2e"/>
                    <TextBlock Text="Build your skills across multiple programming languages"
                               FontSize="13" Foreground="#888" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Info banner -->
        <Border Grid.Row="2" Background="#EEEAFF" CornerRadius="12" Margin="32,24,32,0" Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#8494FF" CornerRadius="8" Width="36" Height="36" Margin="0,0,14,0">
                    <TextBlock Text="⏱" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Test Information" FontWeight="SemiBold" FontSize="15" Foreground="#1a1a2e"/>
                    <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#555" Margin="0,3,0,0"
                               Text="Each test contains a different number of questions and must be completed within 30 minutes. Tests can only be taken once."/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Test grid -->
        <Grid Grid.Row="3">
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Width="48" Height="48" Foreground="#8494FF"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <TextBlock Text="No available tests at the moment."
                       Foreground="#8494FF" FontSize="18"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="{x:Bind ViewModel.NoTestsVisible, Mode=OneWay}"/>

            <ScrollViewer Padding="32,20,32,32" VerticalScrollBarVisibility="Auto">
                <ItemsRepeater x:Name="TestsRepeater"
                               ItemsSource="{x:Bind ViewModel.Tests, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="16"/>
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:TiTestCardViewModel">
                            <Border Background="White" CornerRadius="16" Padding="24"
                                    BorderThickness="{x:Bind CardBorderThickness, Mode=OneWay}"
                                    BorderBrush="{x:Bind CardBorderBrush, Mode=OneWay}"
                                    Tag="{x:Bind}"
                                    PointerEntered="Card_PointerEntered"
                                    PointerExited="Card_PointerExited">
                                <StackPanel Spacing="0">

                                    <!-- Badge row -->
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="#8494FF" CornerRadius="20" Padding="10,5">
                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                <TextBlock Text="&lt;/&gt;" Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                                <TextBlock Text="{x:Bind QuestionTypeLabel}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                            </StackPanel>
                                        </Border>
                                        <Ellipse Grid.Column="2" Width="10" Height="10" Fill="#22c55e" VerticalAlignment="Center"/>
                                    </Grid>

                                    <!-- Title -->
                                    <TextBlock Text="{x:Bind Title}"
                                               FontSize="18" FontWeight="SemiBold" Foreground="#1a1a2e"
                                               TextWrapping="Wrap" Margin="0,0,0,10"/>

                                    <!-- Category badge -->
                                    <Border Background="#F0EEFF" CornerRadius="20" Padding="12,4"
                                            HorizontalAlignment="Left" Margin="0,0,0,12">
                                        <TextBlock Text="{x:Bind Category}" FontSize="12" Foreground="#555"/>
                                    </Border>

                                    <!-- Divider -->
                                    <Border Height="1" Background="#F0EEFF" Margin="0,0,0,12"/>

                                    <!-- Timer info -->
                                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,12">
                                        <TextBlock Text="⏱" FontSize="13" Foreground="#888" VerticalAlignment="Center"/>
                                        <TextBlock Text="30 minutes" FontSize="13" Foreground="#888" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Action buttons -->
                                    <StackPanel Spacing="8">
                                        <Button Content="View Details" Tag="{x:Bind}" Click="ViewDetails_Click"
                                                Background="#8494FF" Foreground="White"
                                                HorizontalAlignment="Stretch" Padding="10,6" CornerRadius="6"/>
                                        <Button Content="View Leaderboard" Tag="{x:Bind}" Click="ViewLeaderboard_Click"
                                                HorizontalAlignment="Stretch" Padding="10,6" CornerRadius="6"/>
                                        <Button Content="Start Test" Tag="{x:Bind}" Click="StartTest_Click"
                                                Background="#22c55e" Foreground="White"
                                                HorizontalAlignment="Stretch" Padding="10,6" CornerRadius="6"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
