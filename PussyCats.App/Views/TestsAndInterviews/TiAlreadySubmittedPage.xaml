<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PussyCats_App.Views.TestsAndInterviews.TiAlreadySubmittedPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="560" Padding="24">
        <Border Background="#FFFBEB" CornerRadius="16" Padding="48,40"
                BorderBrush="#FCD34D" BorderThickness="1">
            <StackPanel Spacing="16" HorizontalAlignment="Center">

                <!-- Icon -->
                <Border Background="#FEF9C3" CornerRadius="40" Width="80" Height="80"
                        HorizontalAlignment="Center">
                    <TextBlock Text="✓" FontSize="40" Foreground="#854D0E"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Title -->
                <TextBlock Text="Already Submitted" FontSize="24" FontWeight="Bold"
                           Foreground="#1a1a2e" HorizontalAlignment="Center"/>

                <!-- Message -->
                <TextBlock Text="You have already completed this test. Your result has been recorded."
                           FontSize="15" Foreground="#666" TextAlignment="Center"
                           TextWrapping="Wrap" HorizontalAlignment="Center" MaxWidth="400"/>

                <!-- Loading ring while fetching attempt -->
                <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                              Width="32" Height="32" HorizontalAlignment="Center"/>

                <!-- Buttons -->
                <StackPanel Spacing="10" Margin="0,8,0,0" MinWidth="280">
                    <Button Content="Return to Dashboard" Click="ReturnToDashboard_Click"
                            HorizontalAlignment="Stretch" Padding="16,10" CornerRadius="8"/>
                    <Button x:Name="ViewAnswersButton" Content="View Submitted Answers"
                            Click="ViewAnswers_Click"
                            Background="#8494FF" Foreground="White"
                            HorizontalAlignment="Stretch" Padding="16,10" CornerRadius="8"
                            IsEnabled="{x:Bind ViewModel.HasAttempt, Mode=OneWay}"/>
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</Page>
