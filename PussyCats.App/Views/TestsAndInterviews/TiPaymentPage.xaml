<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PussyCats_App.Views.TestsAndInterviews.TiPaymentPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <Button Content="← Back" Click="Back_Click" Background="Transparent" BorderThickness="0"/>
            <TextBlock Text="Payment" FontSize="24" FontWeight="Bold" Margin="0,8,0,4"/>
            <TextBlock Text="{x:Bind ViewModel.JobTitle, Mode=OneWay}"
                       FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Payment form -->
            <Border Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="12" Padding="24">
                <StackPanel Spacing="16">
                    <TextBlock Text="Payment Details" FontSize="18" FontWeight="SemiBold"/>

                    <TextBlock Text="{x:Bind ViewModel.ResultMessage, Mode=OneWay}" FontSize="13"
                               Foreground="#22c55e" TextWrapping="Wrap"/>

                    <TextBox Header="Amount ($)" Text="{x:Bind ViewModel.AmountText, Mode=TwoWay}"
                             PlaceholderText="Enter amount" InputScope="Number"/>
                    <TextBox Header="Card Holder Name" Text="{x:Bind ViewModel.CardHolderName, Mode=TwoWay}"/>
                    <TextBox Header="Card Number" Text="{x:Bind ViewModel.CardNumber, Mode=TwoWay}"
                             MaxLength="19" InputScope="Number"/>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Header="Expiration (MM/YY)"
                                 Text="{x:Bind ViewModel.ExpDate, Mode=TwoWay}"
                                 MaxLength="5" PlaceholderText="MM/YY"/>
                        <TextBox Grid.Column="1" Header="CVV" Text="{x:Bind ViewModel.Cvv, Mode=TwoWay}"
                                 MaxLength="4" InputScope="Number"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                        <Button Content="Cancel" Click="Back_Click" Padding="16,8"/>
                        <Button Content="Pay" Click="Pay_Click"
                                Background="#8494FF" Foreground="White" Padding="24,10" CornerRadius="8"
                                IsEnabled="{x:Bind ViewModel.IsProcessing, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Highest paid jobs table -->
            <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="12" Padding="24">
                <StackPanel Spacing="16">
                    <TextBlock Text="Highest Paid Jobs" FontSize="18" FontWeight="SemiBold"/>

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" x:Name="JobTypeFilterCombo" Header="Job Type"
                                  HorizontalAlignment="Stretch" SelectionChanged="FilterCombo_SelectionChanged"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="Full-Time" Tag="Full-Time"/>
                            <ComboBoxItem Content="Part-Time" Tag="Part-Time"/>
                            <ComboBoxItem Content="Internship" Tag="Internship"/>
                        </ComboBox>
                        <ComboBox Grid.Column="1" x:Name="ExpLevelFilterCombo" Header="Experience Level"
                                  HorizontalAlignment="Stretch" SelectionChanged="FilterCombo_SelectionChanged"
                                  SelectedIndex="2">
                            <ComboBoxItem Content="Junior" Tag="Junior"/>
                            <ComboBoxItem Content="Mid-Level" Tag="Mid-Level"/>
                            <ComboBoxItem Content="Senior" Tag="Senior"/>
                        </ComboBox>
                    </Grid>

                    <ListView ItemsSource="{x:Bind ViewModel.PaymentData, Mode=OneWay}" MaxHeight="400">
                        <ListView.Header>
                            <Grid Padding="12,8" Background="{ThemeResource LayerFillColorDefaultBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Company" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="Job Title" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="2" Text="Amount ($)" FontWeight="SemiBold"/>
                            </Grid>
                        </ListView.Header>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="12,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding CompanyName}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1" Text="{Binding JobTitle}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="2" Text="{Binding AmountPayed}"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
