@using PussyCats.Library.Domain.Enums
@model PussyCats.Library.Domain.Match
@{
    ViewData["Title"] = "Applicant Details";
    var canEditDecision = Model.Status is MatchStatus.Applied or MatchStatus.Advanced;
}

<h1>Applicant Details</h1>

<dl class="row">
    <dt class="col-sm-3">Applicant</dt>
    <dd class="col-sm-9">@Model.User?.Name</dd>

    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.User?.Email</dd>

    <dt class="col-sm-3">Job</dt>
    <dd class="col-sm-9">@Model.Job?.JobTitle</dd>

    <dt class="col-sm-3">Company</dt>
    <dd class="col-sm-9">@Model.Job?.Company?.CompanyName</dd>

    <dt class="col-sm-3">Location</dt>
    <dd class="col-sm-9">@Model.Job?.Location</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>

    <dt class="col-sm-3">Last Updated</dt>
    <dd class="col-sm-9">@Model.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</dd>

    <dt class="col-sm-3">Feedback</dt>
    <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.FeedbackMessage) ? "-" : Model.FeedbackMessage)</dd>
</dl>

<a class="btn btn-secondary" asp-action="Index">Back</a>
@if (canEditDecision)
{
    <a class="btn btn-primary" asp-action="Decision" asp-route-id="@Model.MatchId">Accept or Reject</a>
}
